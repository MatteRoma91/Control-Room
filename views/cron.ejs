<section class="mb-8" aria-labelledby="cron-heading">
  <h1 id="cron-heading" class="text-2xl font-bold text-slate-200 mb-6">Cron Jobs (Pianificazione)</h1>
  <p class="text-slate-400 mb-6">Pianifica riavvii PM2, backup database o comandi personalizzati. Formato cron: minuto ora giorno mese giorno_settimana (es. <code class="text-emerald-400">0 4 * * *</code> = ogni giorno alle 04:00, <code class="text-emerald-400">0 4 * * 5</code> = ogni venerdì alle 04:00).</p>

  <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 mb-8">
    <h2 class="text-lg font-semibold text-slate-200 mb-2">Daily App Check (auto-ripristino)</h2>
    <p class="text-slate-400 text-sm mb-4">Controllo automatico giornaliero di tutte le webapp (locale + internet) con tentativo di ripristino automatico in caso di problemi.</p>
    <div class="flex flex-wrap gap-3 items-center mb-4">
      <label class="flex items-center gap-2 text-sm text-slate-300">
        <input type="checkbox" id="dailyCheckEnabled" class="rounded border-slate-600 bg-slate-700" <%= (dailyCheck && dailyCheck.enabled !== false) ? 'checked' : '' %> />
        Attivo
      </label>
      <label class="text-sm text-slate-300">
        Orario
        <input type="time" id="dailyCheckTime" value="<%= (dailyCheck && dailyCheck.time) ? dailyCheck.time : '00:00' %>" class="ml-2 px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100" />
      </label>
      <button type="button" id="btnSaveDailyCheck" class="px-3 py-1.5 rounded bg-emerald-700 hover:bg-emerald-600 text-sm">Salva orario</button>
      <button type="button" id="btnRunDailyCheck" class="px-3 py-1.5 rounded bg-blue-700 hover:bg-blue-600 text-sm" <%= dailyCheckRunning ? 'disabled' : '' %>>Esegui ora</button>
    </div>
    <div class="text-sm text-slate-400 mb-2">Ultimo check: <span id="dailyCheckLastMeta" class="text-slate-300">caricamento...</span></div>
    <pre id="dailyCheckLastReport" class="whitespace-pre-wrap text-xs bg-slate-900/60 border border-slate-700 rounded p-3 text-slate-300 min-h-[80px]"></pre>
  </div>

  <script>window.cronProcesses = <%- JSON.stringify((processes && processes.length) ? processes.map(p => p.name) : ['padel-tour','roma-buche','gestione-veicoli','control-room']) %>;</script>
  <div class="space-y-4 mb-8" id="cronJobsList">
    <% (cronJobs || []).forEach((job) => { %>
    <div class="cron-job-card flex flex-wrap items-center gap-4 p-4 rounded-lg border border-slate-700 bg-slate-800" data-id="<%= job.id %>">
      <div class="flex-1 min-w-0 space-y-2">
        <input type="text" class="cron-name w-full bg-transparent border-b border-slate-600 px-0 py-1 text-slate-200 font-medium focus:ring-0 focus:border-emerald-500" value="<%= (job.name || '') %>" placeholder="Nome" />
        <input type="text" class="cron-schedule block w-full bg-transparent border-b border-slate-600 px-0 py-1 text-slate-400 font-mono text-sm focus:ring-0 focus:border-emerald-500" value="<%= (job.schedule || '') %>" placeholder="0 4 * * *" />
        <div class="flex flex-wrap gap-2 items-center mt-2">
          <select class="cron-action px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm">
            <option value="pm2-restart" <%= (job.action || 'pm2-restart') === 'pm2-restart' ? 'selected' : '' %>>Riavvia PM2</option>
            <option value="pm2-start" <%= job.action === 'pm2-start' ? 'selected' : '' %>>Avvia PM2</option>
            <option value="command" <%= job.action === 'command' ? 'selected' : '' %>>Comando</option>
            <option value="db-backup" <%= job.action === 'db-backup' ? 'selected' : '' %>>Backup DB</option>
          </select>
          <span class="cron-target-wrap" style="<%= (job.action === 'pm2-restart' || job.action === 'pm2-start') ? '' : 'display:none' %>">
            <select class="cron-target px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm">
              <% (processes || [{name:'padel-tour'},{name:'roma-buche'},{name:'gestione-veicoli'},{name:'control-room'}]).forEach((p) => { %>
              <option value="<%= p.name %>" <%= (job.target || '') === p.name ? 'selected' : '' %>><%= p.name %></option>
              <% }); %>
            </select>
          </span>
          <span class="cron-command-wrap" style="<%= job.action === 'command' ? '' : 'display:none' %>">
            <input type="text" class="cron-command px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm font-mono" value="<%= (job.command || '') %>" placeholder="/path/to/script.sh" style="min-width: 200px" />
          </span>
        </div>
      </div>
      <label class="flex items-center gap-2 shrink-0">
        <input type="checkbox" class="cron-enabled rounded border-slate-600 bg-slate-700" <%= job.enabled !== false ? 'checked' : '' %> />
        <span class="text-sm text-slate-300">Attivo</span>
      </label>
      <button type="button" class="cron-remove px-2 py-1 rounded text-red-400 hover:text-red-300 text-sm shrink-0">Rimuovi</button>
    </div>
    <% }); %>
  </div>

  <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 mb-6">
    <h2 class="text-lg font-semibold text-slate-200 mb-4">Aggiungi job</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-sm text-slate-400 mb-1">Nome</label>
        <input type="text" id="cronName" placeholder="Es: Riavvia Padel ogni notte" class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100" />
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">Schedule (cron)</label>
        <div class="flex gap-2">
          <input type="text" id="cronSchedule" placeholder="0 4 * * *  (ogni giorno alle 04:00)" class="flex-1 px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono" />
          <select id="cronSchedulePreset" class="px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 text-sm" title="Preset rapidi">
            <option value="">Preset...</option>
            <option value="0 4 * * *">Ogni notte 04:00</option>
            <option value="0 4 * * 5">Ogni venerdì 04:00</option>
            <option value="0 */2 * * *">Ogni 2 ore</option>
            <option value="0 * * * *">Ogni ora</option>
            <option value="*/15 * * * *">Ogni 15 min</option>
          </select>
          <button type="button" id="btnPreviewCron" class="px-3 py-2 rounded-lg bg-slate-600 hover:bg-slate-500 text-sm">Preview</button>
        </div>
        <div id="cronPreviewOut" class="mt-2 text-xs text-slate-400"></div>
      </div>
      <div>
        <label class="block text-sm text-slate-400 mb-1">Azione</label>
        <select id="cronAction" class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100">
          <option value="pm2-restart">Riavvia processo PM2</option>
          <option value="pm2-start">Avvia processo PM2</option>
          <option value="command">Comando shell</option>
          <option value="db-backup">Backup database</option>
        </select>
      </div>
      <div id="cronTargetWrap">
        <label class="block text-sm text-slate-400 mb-1">Processo PM2</label>
        <select id="cronTarget" class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100">
          <% (processes || []).forEach((p) => { %>
          <option value="<%= p.name %>"><%= p.name %></option>
          <% }); %>
          <% if (!processes || processes.length === 0) { %><option value="padel-tour">padel-tour</option><option value="roma-buche">roma-buche</option><option value="gestione-veicoli">gestione-veicoli</option><option value="control-room">control-room</option><% } %>
        </select>
      </div>
      <div id="cronCommandWrap" class="hidden">
        <label class="block text-sm text-slate-400 mb-1">Comando</label>
        <input type="text" id="cronCommand" placeholder="/home/ubuntu/scripts/backup.sh" class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono" />
      </div>
      <p id="cronDbBackupNote" class="hidden text-sm text-slate-500">Salva in backups/ (richiede DB configurato in .env)</p>
      <button type="button" id="btnAddCron" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500">
        Aggiungi
      </button>
    </div>
  </div>

  <button type="button" id="btnSaveCron" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500">
    Salva configurazione
  </button>

  <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 mt-6">
    <h2 class="text-lg font-semibold text-slate-200 mb-2">Storico esecuzioni cron</h2>
    <div id="cronHistory" class="text-xs text-slate-300 font-mono whitespace-pre-wrap">Caricamento...</div>
  </div>
</section>

<script>
  document.getElementById('cronAction').addEventListener('change', function() {
    const v = this.value;
    document.getElementById('cronTargetWrap').classList.toggle('hidden', v !== 'pm2-restart' && v !== 'pm2-start');
    document.getElementById('cronCommandWrap').classList.toggle('hidden', v !== 'command');
    document.getElementById('cronDbBackupNote').classList.toggle('hidden', v !== 'db-backup');
  });
  document.getElementById('cronAction').dispatchEvent(new Event('change'));

  document.getElementById('cronSchedulePreset').addEventListener('change', function() {
    const val = this.value;
    if (val) {
      document.getElementById('cronSchedule').value = val;
      this.value = '';
    }
  });

  document.getElementById('btnPreviewCron').addEventListener('click', async function() {
    const schedule = document.getElementById('cronSchedule').value.trim();
    const out = document.getElementById('cronPreviewOut');
    if (!schedule) {
      out.textContent = 'Inserisci uno schedule.';
      return;
    }
    out.textContent = 'Calcolo in corso...';
    try {
      const res = await fetch('/api/cron-jobs/preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ schedule }),
      });
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'Schedule non valido');
      out.textContent = 'Prossima esecuzione: ' + (json.nextRuns[0] ? new Date(json.nextRuns[0]).toLocaleString('it-IT') : 'n/d');
    } catch (err) {
      out.textContent = 'Errore preview: ' + err.message;
    }
  });

  function collectCronJobs() {
    return Array.from(document.querySelectorAll('.cron-job-card')).map(card => {
      const action = card.querySelector('.cron-action')?.value || 'pm2-restart';
      return {
        id: card.dataset.id,
        name: card.querySelector('.cron-name')?.value?.trim() || '',
        schedule: card.querySelector('.cron-schedule')?.value?.trim() || '',
        enabled: card.querySelector('.cron-enabled')?.checked !== false,
        action,
        target: action === 'pm2-restart' || action === 'pm2-start' ? (card.querySelector('.cron-target')?.value || '') : '',
        command: action === 'command' ? (card.querySelector('.cron-command')?.value?.trim() || '') : ''
      };
    }).filter(j => j.schedule);
  }

  function bindCronActionToggle(card) {
    const actionSelect = card.querySelector('.cron-action');
    const targetWrap = card.querySelector('.cron-target-wrap');
    const commandWrap = card.querySelector('.cron-command-wrap');
    if (!actionSelect) return;
    actionSelect.addEventListener('change', function() {
      const v = this.value;
      targetWrap.style.display = (v === 'pm2-restart' || v === 'pm2-start') ? '' : 'none';
      commandWrap.style.display = v === 'command' ? '' : 'none';
    });
  }

  function addCronCard(job) {
    const processes = window.cronProcesses || ['padel-tour', 'roma-buche', 'gestione-veicoli', 'control-room'];
    const targetOpts = processes.map(p => {
      const name = typeof p === 'string' ? p : p.name;
      const sel = (job.target || 'padel-tour') === name ? ' selected' : '';
      return `<option value="${name}"${sel}>${name}</option>`;
    }).join('');
    const card = document.createElement('div');
    card.className = 'cron-job-card flex flex-wrap items-center gap-4 p-4 rounded-lg border border-slate-700 bg-slate-800';
    card.dataset.id = job.id || 'cron-' + Date.now();
    const showTarget = job.action === 'pm2-restart' || job.action === 'pm2-start';
    const showCommand = job.action === 'command';
    card.innerHTML = `
      <div class="flex-1 min-w-0 space-y-2">
        <input type="text" class="cron-name w-full bg-transparent border-b border-slate-600 px-0 py-1 text-slate-200 font-medium" value="${(job.name || '').replace(/"/g, '&quot;')}" placeholder="Nome" />
        <input type="text" class="cron-schedule block w-full bg-transparent border-b border-slate-600 px-0 py-1 text-slate-400 font-mono text-sm" value="${(job.schedule || '').replace(/"/g, '&quot;')}" placeholder="0 4 * * *" />
        <div class="flex flex-wrap gap-2 items-center mt-2">
          <select class="cron-action px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm">
            <option value="pm2-restart" ${(job.action || 'pm2-restart') === 'pm2-restart' ? 'selected' : ''}>Riavvia PM2</option>
            <option value="pm2-start" ${job.action === 'pm2-start' ? 'selected' : ''}>Avvia PM2</option>
            <option value="command" ${job.action === 'command' ? 'selected' : ''}>Comando</option>
            <option value="db-backup" ${job.action === 'db-backup' ? 'selected' : ''}>Backup DB</option>
          </select>
          <span class="cron-target-wrap" style="${showTarget ? '' : 'display:none'}">
            <select class="cron-target px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm">${targetOpts}</select>
          </span>
          <span class="cron-command-wrap" style="${showCommand ? '' : 'display:none'}">
            <input type="text" class="cron-command px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100 text-sm font-mono" value="${(job.command || '').replace(/"/g, '&quot;')}" placeholder="/path/to/script.sh" style="min-width: 200px" />
          </span>
        </div>
      </div>
      <label class="flex items-center gap-2 shrink-0">
        <input type="checkbox" class="cron-enabled rounded border-slate-600 bg-slate-700" ${job.enabled !== false ? 'checked' : ''} />
        <span class="text-sm text-slate-300">Attivo</span>
      </label>
      <button type="button" class="cron-remove px-2 py-1 rounded text-red-400 hover:text-red-300 text-sm shrink-0">Rimuovi</button>
    `;
    card.querySelector('.cron-remove').addEventListener('click', () => card.remove());
    bindCronActionToggle(card);
    return card;
  }

  document.getElementById('btnAddCron').addEventListener('click', function() {
    const name = document.getElementById('cronName').value.trim();
    const schedule = document.getElementById('cronSchedule').value.trim();
    const action = document.getElementById('cronAction').value;
    const target = document.getElementById('cronTarget').value;
    const command = document.getElementById('cronCommand').value.trim();
    if (!schedule) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Inserisci uno schedule cron', type: 'error' } }));
      return;
    }
    const card = addCronCard({ name, schedule, action, target, command, enabled: true });
    document.getElementById('cronJobsList').appendChild(card);
    document.getElementById('cronName').value = '';
    document.getElementById('cronSchedule').value = '';
    document.getElementById('cronCommand').value = '';
  });

  document.querySelectorAll('.cron-job-card').forEach(card => {
    bindCronActionToggle(card);
    card.querySelector('.cron-remove')?.addEventListener('click', () => card.remove());
  });

  document.getElementById('btnSaveCron').addEventListener('click', async function() {
    const jobs = collectCronJobs();
    try {
      const res = await fetch('/api/cron-jobs', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ jobs }),
      });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Cron jobs salvati', type: 'success' } }));
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Salvataggio fallito'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  function renderDailyCheckStatus(payload) {
    const meta = document.getElementById('dailyCheckLastMeta');
    const report = document.getElementById('dailyCheckLastReport');
    const runBtn = document.getElementById('btnRunDailyCheck');
    if (!payload) {
      meta.textContent = 'nessun dato';
      report.textContent = 'Nessun check eseguito.';
      return;
    }
    if (payload.running) runBtn.setAttribute('disabled', 'disabled');
    else runBtn.removeAttribute('disabled');
    if (!payload.lastRun) {
      meta.textContent = 'mai eseguito';
      report.textContent = 'Nessun check eseguito.';
      return;
    }
    const lr = payload.lastRun;
    meta.textContent = `${new Date(lr.startedAt).toLocaleString('it-IT')} | esito: ${lr.overall}`;
    const lines = (lr.entries || []).map(function(e) {
      return `${e.name} [${e.process}] -> ${e.status} | PM2 ${e.pm2Before}=>${e.pm2After} | local ${e.localStatusBefore}=>${e.localStatusAfter} | public ${e.publicStatusBefore}=>${e.publicStatusAfter} | azioni: ${(e.actions || []).join(', ') || '-'}`;
    });
    report.textContent = lines.length ? lines.join('\n') : 'Nessun dettaglio disponibile.';
  }

  async function loadDailyCheckStatus() {
    try {
      const res = await fetch('/api/daily-check/status');
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'Errore caricamento');
      const cfg = json.config || {};
      document.getElementById('dailyCheckEnabled').checked = cfg.enabled !== false;
      document.getElementById('dailyCheckTime').value = cfg.time || '00:00';
      renderDailyCheckStatus(json);
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore daily check: ' + err.message, type: 'error' } }));
    }
  }

  document.getElementById('btnSaveDailyCheck').addEventListener('click', async function() {
    const enabled = document.getElementById('dailyCheckEnabled').checked;
    const time = document.getElementById('dailyCheckTime').value || '00:00';
    try {
      const res = await fetch('/api/daily-check/config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ enabled, time }),
      });
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'Salvataggio fallito');
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Configurazione daily check salvata', type: 'success' } }));
      await loadDailyCheckStatus();
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('btnRunDailyCheck').addEventListener('click', async function() {
    this.setAttribute('disabled', 'disabled');
    try {
      const res = await fetch('/api/daily-check/run', { method: 'POST' });
      const json = await res.json();
      if (!json.ok) throw new Error(json.message || json.error || 'Esecuzione fallita');
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Daily check completato: ' + json.report.overall, type: json.report.overall === 'failed' ? 'error' : 'success' } }));
      await loadDailyCheckStatus();
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    } finally {
      this.removeAttribute('disabled');
    }
  });

  async function loadCronHistory() {
    try {
      const res = await fetch('/api/cron-jobs/history');
      const json = await res.json();
      const history = json.history || [];
      const out = document.getElementById('cronHistory');
      if (!history.length) {
        out.textContent = 'Nessuna esecuzione registrata.';
        return;
      }
      out.textContent = history.slice(0, 20).map(function(h) {
        return `${new Date(h.startedAt).toLocaleString('it-IT')} | ${h.name || h.id} | ${h.action} | ${h.success ? 'OK' : 'FAIL'} | ${h.message || '-'}`;
      }).join('\n');
    } catch (err) {
      document.getElementById('cronHistory').textContent = 'Errore caricamento storico: ' + err.message;
    }
  }

  loadDailyCheckStatus();
  loadCronHistory();
</script>
