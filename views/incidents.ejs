<section class="space-y-6" aria-labelledby="incidents-heading">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 id="incidents-heading" class="text-2xl font-bold text-cr-text">Incident Center</h1>
      <p class="text-sm text-cr-muted mt-1 max-w-2xl">Traccia outage e lavoro operativo. Da qui crei ticket, passi ad ACK e Resolved quando chiudi.</p>
    </div>
    <button type="button" id="btnRefreshIncidents" class="min-h-[44px] px-3 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm font-medium">Aggiorna</button>
  </div>

  <div class="rounded-lg border border-cr-border bg-cr-surface p-4">
    <h2 class="text-lg font-semibold text-cr-text mb-1">Nuovo incidente</h2>
    <p class="text-xs text-cr-muted mb-3">Titolo chiaro (es. «502 su padel-tour») e gravità coerente con l’impatto.</p>
    <form id="incidentCreateForm" class="grid grid-cols-1 md:grid-cols-4 gap-3">
      <input id="incidentTitle" class="md:col-span-2 rounded bg-cr-surface2 border border-cr-inputBorder px-3 py-2" placeholder="Titolo incidente" />
      <select id="incidentSeverity" class="rounded bg-cr-surface2 border border-cr-inputBorder px-3 py-2">
        <option value="medium">medium</option>
        <option value="high">high</option>
        <option value="critical">critical</option>
        <option value="low">low</option>
      </select>
      <button class="rounded bg-cr-accent hover:bg-cr-accent px-3 py-2">Crea</button>
    </form>
  </div>

  <div id="incidentsList" class="space-y-3"></div>
</section>

<script>
  async function loadIncidents() {
    const root = document.getElementById('incidentsList');
    try {
      const res = await fetch('/api/incidents');
      const data = await res.json();
      const incidents = data.incidents || [];
      if (!incidents.length) {
        root.innerHTML = '<div class="rounded-xl border border-dashed border-cr-border bg-cr-surface2/50 p-8 text-center"><p class="text-cr-text font-medium mb-1">Nessun incidente aperto in elenco</p><p class="text-sm text-cr-muted">Crea il primo con il modulo sopra oppure collega notifiche da <a href="/settings#settings-notifications" class="text-cr-accent hover:underline">Impostazioni → Notifiche</a>.</p></div>';
        return;
      }
      root.innerHTML = incidents.map((i) => `
        <div class="rounded-lg border border-cr-border bg-cr-surface p-4">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
              <p class="font-semibold">${i.title}</p>
              <p class="text-xs text-cr-muted">severity=${i.severity} · status=${i.status} · updated=${i.updatedAt || '-'}</p>
            </div>
            <div class="flex gap-2">
              <button onclick="updateIncidentStatus('${i.id}','ack')" class="px-2 py-1 rounded bg-cr-warning hover:opacity-90 text-white dark:text-slate-900 text-xs font-medium">ACK</button>
              <button onclick="updateIncidentStatus('${i.id}','resolved')" class="px-2 py-1 rounded bg-cr-accent hover:bg-cr-accent text-xs">Resolve</button>
            </div>
          </div>
        </div>
      `).join('');
    } catch (err) {
      root.innerHTML = `<div class="text-cr-danger">Errore: ${err.message}</div>`;
    }
  }

  async function updateIncidentStatus(id, status) {
    const res = await fetch(`/api/incidents/${encodeURIComponent(id)}/status`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    const json = await res.json();
    if (!json.ok) window.dispatchEvent(new CustomEvent('toast', { detail: { message: json.error || 'Errore aggiornamento incidente', type: 'error' } }));
    loadIncidents();
  }

  document.getElementById('incidentCreateForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const title = document.getElementById('incidentTitle').value.trim();
    const severity = document.getElementById('incidentSeverity').value;
    const res = await fetch('/api/incidents', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, severity }),
    });
    const json = await res.json();
    if (!json.ok) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: json.error || 'Errore creazione incidente', type: 'error' } }));
      return;
    }
    document.getElementById('incidentTitle').value = '';
    loadIncidents();
  });

  document.getElementById('btnRefreshIncidents').addEventListener('click', loadIncidents);
  loadIncidents();
</script>
