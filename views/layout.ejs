<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0d9488">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Control Room">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Control Room</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png">
  <link rel="manifest" href="/manifest.json">
  <script>
    /** Drawer: posizione da CSS (theme.css) + classe cr-drawer-open; niente mdUp / x-bind:style. */
    function crSidebarShell() {
      return {
        sidebarOpen: false,
        toggleSidebar() {
          this.sidebarOpen = !this.sidebarOpen;
          // #region agent log
          if (typeof fetch === 'function') {
            fetch('/api/_agent-debug',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({sessionId:'fccd24',location:'layout.ejs:toggleSidebar',message:'hamburger toggle',data:{sidebarOpen:this.sidebarOpen,iw:typeof window!=='undefined'&&typeof window.innerWidth==='number'?window.innerWidth:null,vvW:typeof window!=='undefined'&&window.visualViewport?window.visualViewport.width:null},timestamp:Date.now(),runId:'alpine-click',hypothesisId:'H2'})}).catch(function(){});
          }
          // #endregion
        },
        init() {
          var self = this;
          function closeDrawerIfDesktop() {
            if (typeof window !== 'undefined' && typeof window.innerWidth === 'number' && window.innerWidth >= 768) {
              self.sidebarOpen = false;
            }
          }
          closeDrawerIfDesktop();
          // #region agent log
          if (typeof fetch === 'function' && typeof window !== 'undefined' && typeof window.innerWidth === 'number') {
            fetch('/api/_agent-debug',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify({sessionId:'fccd24',location:'layout.ejs:init',message:'alpine init',data:{iw:window.innerWidth,vvW:window.visualViewport?window.visualViewport.width:null,sidebarOpen:self.sidebarOpen},timestamp:Date.now(),runId:'alpine-click',hypothesisId:'H1'})}).catch(function(){});
          }
          // #endregion
          window.addEventListener('resize', closeDrawerIfDesktop, { passive: true });
          if (window.visualViewport) {
            window.visualViewport.addEventListener('resize', closeDrawerIfDesktop, { passive: true });
          }
        },
      };
    }
  </script>
  <%- include('partials/head-common') %>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script defer src="/js/cr-theme.js"></script>
  <%- typeof headExtra !== 'undefined' ? headExtra : '' %>
</head>
<body class="min-h-screen bg-cr-canvas text-cr-text font-sans antialiased" x-data="crSidebarShell()">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cr-nav border-b border-cr-border px-3 md:px-4 py-2.5 flex justify-between items-center gap-2 shadow-sm isolate">
    <div class="flex items-center gap-2 md:gap-3 min-w-0">
      <button
        type="button"
        id="cr-nav-menu-btn"
        class="md:hidden touch-manipulation cursor-pointer p-2 rounded-lg hover:bg-cr-navHover text-cr-text focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav shrink-0 min-h-[44px] min-w-[44px] flex items-center justify-center relative z-10"
        aria-label="Apri o chiudi menu"
        @click.stop="toggleSidebar()"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <div class="min-w-0 hidden sm:block">
        <h1 class="text-lg md:text-xl font-bold tracking-tight truncate text-cr-text">Control Room</h1>
        <p class="hidden md:block text-xs text-cr-muted truncate">Ops console · recovery · incidenti · sicurezza</p>
      </div>
      <div class="min-w-0 sm:hidden">
        <h1 class="text-base font-bold truncate">CR</h1>
      </div>
    </div>
    <div class="flex items-center gap-1.5 md:gap-2 shrink-0">
      <button
        type="button"
        data-cr-theme-cycle
        class="p-2 rounded-lg border border-cr-border bg-cr-surface hover:bg-cr-surface2 text-cr-muted hover:text-cr-text focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav min-h-[44px] min-w-[44px] flex flex-col items-center justify-center leading-none"
        title="Cambia tema"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <span class="text-[9px] font-medium text-cr-muted mt-0.5 max-w-[52px] truncate hidden md:inline" data-cr-theme-label>Sistema</span>
      </button>
      <div class="hidden lg:flex items-center gap-1 flex-wrap justify-end max-w-[52rem]">
        <% var hp = typeof reqPath !== 'undefined' ? reqPath : ''; %>
        <a href="/incidents" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/incidents' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/incidents' ? 'page' : 'false' %>">Incidenti</a>
        <a href="/automation" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/automation' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/automation' ? 'page' : 'false' %>">Automation</a>
        <a href="/analytics" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/analytics' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/analytics' ? 'page' : 'false' %>">Analytics</a>
        <a href="/settings" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp.indexOf('/settings') === 0 ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp.indexOf('/settings') === 0 ? 'page' : 'false' %>">Impostazioni</a>
        <a href="/cron" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/cron' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/cron' ? 'page' : 'false' %>">Cron</a>
        <a href="/nginx" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/nginx' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/nginx' ? 'page' : 'false' %>">Nginx</a>
        <a href="/audit" class="px-2.5 py-1.5 rounded-md text-sm border transition-colors focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav <%= hp === '/audit' ? 'border-cr-accent bg-cr-surface2 text-cr-accent font-medium' : 'border-transparent bg-cr-surface2 hover:bg-cr-navHover text-cr-text' %>" aria-current="<%= hp === '/audit' ? 'page' : 'false' %>">Audit</a>
      </div>
      <form method="POST" action="/logout" class="inline">
        <button type="submit" class="px-3 py-2 rounded-md bg-cr-surface2 hover:bg-cr-navHover border border-cr-border text-sm font-medium focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-nav">Logout</button>
      </form>
    </div>
  </nav>

  <div
    x-show="sidebarOpen"
    x-transition:enter="transition-opacity duration-200"
    x-transition:leave="transition-opacity duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="sidebarOpen = false"
    @keydown.escape.window="sidebarOpen = false"
    class="md:hidden fixed inset-0 z-20 bg-black/40 dark:bg-black/50"
    style="display: none;"
    aria-hidden="true"
  ></div>
  <aside
    id="cr-sidebar"
    class="fixed inset-y-0 left-0 z-30 w-[17rem] pointer-events-none md:pointer-events-auto bg-cr-nav border-r border-cr-border shadow-lg md:shadow-none"
    :class="sidebarOpen ? 'cr-drawer-open' : ''"
    aria-label="Navigazione principale"
  >
    <div class="cr-sidebar-inner pointer-events-auto flex min-h-0 flex-col mt-14 h-[calc(100%-3.5rem)] md:mt-0 md:h-full md:pt-16">
      <%- include('partials/sidebar') %>
    </div>
  </aside>

  <main class="pt-14 md:pt-16 md:pl-[17rem] min-h-screen overflow-x-hidden">
    <div class="p-4 md:p-6 max-w-7xl mx-auto">
      <%- include('partials/toast') %>
      <%- include('partials/confirm-modal') %>
      <%- include('partials/git-pull-modal') %>
      <%- include('partials/env-editor-modal') -%>
      <%- include(contentPartial || 'dashboard') %>
    </div>
  </main>

  <%- typeof scripts !== 'undefined' ? scripts : '' %>
  <%- include('partials/password-toggle-script') %>
</body>
</html>
