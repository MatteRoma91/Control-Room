<div
  id="gitPullModal"
  class="fixed inset-0 z-50"
  x-data="{ open: false, output: '', loading: false }"
  x-on:git-pull-show.window="open = true; output = $event.detail?.output ?? ''; loading = $event.detail?.loading ?? false"
  x-on:git-pull-hide.window="open = false"
  x-show="open"
  x-cloak
  style="display: none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="git-pull-title"
>
  <div class="absolute inset-0 bg-[var(--cr-overlay)] backdrop-blur-[2px]" @click="$dispatch('git-pull-hide')"></div>
  <div class="absolute inset-4 md:inset-10 bg-cr-surface rounded-xl border border-cr-border flex flex-col shadow-xl overflow-hidden">
    <div class="flex justify-between items-center p-4 border-b border-cr-border bg-cr-nav">
      <h2 id="git-pull-title" class="text-lg font-semibold text-cr-text">Git Pull Output</h2>
      <button
        type="button"
        @click="$dispatch('git-pull-hide')"
        class="p-2 rounded-lg hover:bg-cr-navHover text-cr-muted hover:text-cr-text focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface"
        aria-label="Chiudi"
      >
        <span class="text-xl leading-none" aria-hidden="true">&times;</span>
      </button>
    </div>
    <pre class="flex-1 p-4 m-4 overflow-auto text-xs font-mono text-cr-text bg-cr-code border border-cr-border rounded-lg whitespace-pre-wrap" x-text="output || (loading ? 'Esecuzione in corso...' : '')"></pre>
  </div>
</div>
