<div
  id="confirmModal"
  class="fixed inset-0 z-50"
  x-data="confirmModalState()"
  x-show="open"
  x-cloak
  style="display:none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-modal-title"
>
  <div class="absolute inset-0 bg-[var(--cr-overlay)] backdrop-blur-[2px]" @click="cancel()"></div>
  <div class="absolute inset-4 md:inset-x-[25%] md:top-[18%] md:bottom-auto bg-cr-surface rounded-xl border border-cr-border p-5 shadow-xl">
    <h2 id="confirm-modal-title" class="text-lg font-semibold text-cr-text mb-2" x-text="title"></h2>
    <p class="text-sm text-cr-muted mb-4" x-text="message"></p>
    <p class="text-xs text-cr-warning font-medium mb-2">Inserisci la frase di conferma:</p>
    <div class="font-mono text-xs text-cr-accent mb-2 break-all" x-text="expectedPhrase"></div>
    <input
      type="text"
      class="w-full px-3 py-2 rounded-lg bg-cr-input border border-cr-inputBorder text-cr-text mb-4 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface"
      x-model="typedPhrase"
      placeholder="Digita la frase esatta"
    />
    <div class="flex gap-2 justify-end flex-wrap">
      <button type="button" @click="cancel()" class="px-4 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-cr-text text-sm font-medium focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface">Annulla</button>
      <button type="button" @click="confirm()" :disabled="typedPhrase !== expectedPhrase" class="px-4 py-2 rounded-lg bg-cr-danger hover:opacity-90 text-white text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-danger focus:ring-offset-2 focus:ring-offset-cr-surface">Conferma</button>
    </div>
  </div>
</div>

<script>
  function confirmModalState() {
    return {
      open: false,
      title: 'Conferma operazione',
      message: '',
      expectedPhrase: '',
      typedPhrase: '',
      resolver: null,
      openModal(opts) {
        this.title = opts.title || 'Conferma operazione';
        this.message = opts.message || 'Questa azione è ad alto rischio.';
        this.expectedPhrase = opts.expectedPhrase || '';
        this.typedPhrase = '';
        this.open = true;
        return new Promise((resolve) => { this.resolver = resolve; });
      },
      cancel() {
        this.open = false;
        if (this.resolver) this.resolver({ ok: false });
        this.resolver = null;
      },
      confirm() {
        if (this.typedPhrase !== this.expectedPhrase) return;
        this.open = false;
        if (this.resolver) this.resolver({ ok: true, confirmPhrase: this.typedPhrase });
        this.resolver = null;
      },
    };
  }

  async function requestStrongConfirm(options) {
    const modal = document.querySelector('#confirmModal');
    if (!modal || !modal.__x) return { ok: false };
    return modal.__x.$data.openModal(options);
  }
</script>
