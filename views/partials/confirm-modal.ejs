<div
  id="confirmModal"
  class="fixed inset-0 z-50"
  x-data="confirmModalState()"
  x-show="open"
  x-cloak
  style="display:none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-modal-title"
>
  <div class="absolute inset-0 bg-black/60" @click="cancel()"></div>
  <div class="absolute inset-4 md:inset-x-[25%] md:top-[18%] md:bottom-auto bg-slate-800 rounded-lg border border-slate-700 p-5">
    <h2 id="confirm-modal-title" class="text-lg font-semibold text-slate-100 mb-2" x-text="title"></h2>
    <p class="text-sm text-slate-300 mb-4" x-text="message"></p>
    <p class="text-xs text-amber-300 mb-2">Inserisci la frase di conferma:</p>
    <div class="font-mono text-xs text-emerald-300 mb-2" x-text="expectedPhrase"></div>
    <input
      type="text"
      class="w-full px-3 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 mb-4 font-mono"
      x-model="typedPhrase"
      placeholder="Digita la frase esatta"
    />
    <div class="flex gap-2 justify-end">
      <button type="button" @click="cancel()" class="px-4 py-2 rounded bg-slate-600 hover:bg-slate-500">Annulla</button>
      <button type="button" @click="confirm()" :disabled="typedPhrase !== expectedPhrase" class="px-4 py-2 rounded bg-red-700 hover:bg-red-600 disabled:opacity-50 disabled:cursor-not-allowed">Conferma</button>
    </div>
  </div>
</div>

<script>
  function confirmModalState() {
    return {
      open: false,
      title: 'Conferma operazione',
      message: '',
      expectedPhrase: '',
      typedPhrase: '',
      resolver: null,
      openModal(opts) {
        this.title = opts.title || 'Conferma operazione';
        this.message = opts.message || 'Questa azione è ad alto rischio.';
        this.expectedPhrase = opts.expectedPhrase || '';
        this.typedPhrase = '';
        this.open = true;
        return new Promise((resolve) => { this.resolver = resolve; });
      },
      cancel() {
        this.open = false;
        if (this.resolver) this.resolver({ ok: false });
        this.resolver = null;
      },
      confirm() {
        if (this.typedPhrase !== this.expectedPhrase) return;
        this.open = false;
        if (this.resolver) this.resolver({ ok: true, confirmPhrase: this.typedPhrase });
        this.resolver = null;
      },
    };
  }

  async function requestStrongConfirm(options) {
    const modal = document.querySelector('#confirmModal');
    if (!modal || !modal.__x) return { ok: false };
    return modal.__x.$data.openModal(options);
  }
</script>
