<div
  x-data="{ toasts: [], lastToast: { message: null, type: null, ts: 0 } }"
  x-on:toast.window="(() => { const now = Date.now(); const msg = $event.detail.message; const type = $event.detail.type || 'info'; if (lastToast.message === msg && lastToast.type === type && now - lastToast.ts < 1500) return; const t = { id: now, message: msg, type }; lastToast = { message: msg, type, ts: now }; toasts.push(t); setTimeout(() => { toasts = toasts.filter(x => x.id !== t.id) }, 4000); })()"
  class="fixed top-20 right-4 z-50 space-y-2"
  aria-live="polite"
>
  <template x-for="t in toasts" :key="t.id">
    <div
      x-show="true"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 translate-x-8"
      x-transition:enter-end="opacity-100 translate-x-0"
      :class="{
        'bg-emerald-900/90 border-emerald-600': t.type === 'success',
        'bg-red-900/90 border-red-600': t.type === 'error',
        'bg-slate-700/90 border-slate-600': t.type === 'info'
      }"
      class="px-4 py-3 rounded-lg border shadow-lg text-slate-100"
      x-text="t.message"
    ></div>
  </template>
</div>
