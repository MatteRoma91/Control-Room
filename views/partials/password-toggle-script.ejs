<script>
(function() {
  const HOLD_MS = 3000;

  function initPasswordToggle(container) {
    const seconds = parseInt(container.getAttribute('data-password-toggle') || '3', 10);
    const holdMs = seconds * 1000;
    const input = container.querySelector('input[type="password"], input[type="text"]');
    const btn = container.querySelector('[data-password-toggle-btn]');
    if (!input || !btn) return;

    let holdTimer = null;
    let progressInterval = null;
    let isRevealed = false;

    function reveal() {
      isRevealed = true;
      input.type = 'text';
      btn.setAttribute('aria-label', 'Nascondi password');
      btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>';
      btn.classList.remove('text-cr-muted');
      btn.classList.add('text-cr-accent');
    }

    function hide() {
      isRevealed = false;
      input.type = 'password';
      btn.setAttribute('aria-label', 'Mostra password (tieni premuto ' + seconds + ' secondi)');
      btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
      btn.classList.add('text-cr-muted');
      btn.classList.remove('text-cr-accent');
      btn.style.background = '';
    }

    function clearHoldTimer() {
      if (holdTimer) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
      if (progressInterval) {
        clearInterval(progressInterval);
        progressInterval = null;
      }
    }

    btn.addEventListener('mousedown', function(e) {
      e.preventDefault();
      if (isRevealed) {
        hide();
        return;
      }
      clearHoldTimer();
      const start = Date.now();
      progressInterval = setInterval(function() {
        const elapsed = Date.now() - start;
        const pct = Math.min(100, (elapsed / holdMs) * 100);
        btn.style.background = 'linear-gradient(to right, rgba(16,185,129,0.4) 0%, rgba(16,185,129,0.4) ' + pct + '%, transparent ' + pct + '%)';
        if (pct >= 100) clearInterval(progressInterval);
      }, 50);
      holdTimer = setTimeout(function() {
        clearInterval(progressInterval);
        reveal();
        clearHoldTimer();
      }, holdMs);
    });

    btn.addEventListener('mouseup', function() {
      if (!isRevealed && holdTimer) clearHoldTimer();
      btn.style.background = '';
    });
    btn.addEventListener('mouseleave', function() {
      if (!isRevealed && holdTimer) clearHoldTimer();
      btn.style.background = '';
    });

    ['touchstart', 'touchend', 'touchcancel'].forEach(function(ev) {
      btn.addEventListener(ev, function(e) {
        if (ev === 'touchstart') {
          e.preventDefault();
          btn.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
        } else if (ev === 'touchend' || ev === 'touchcancel') {
          btn.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
        }
      }, { passive: ev !== 'touchstart' });
    });

    hide();
  }

  function run() {
    document.querySelectorAll('[data-password-toggle]').forEach(initPasswordToggle);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
})();
</script>
