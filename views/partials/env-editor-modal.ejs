<div
  id="envEditorModal"
  class="fixed inset-0 z-50"
  x-data="envEditorModal()"
  x-on:env-editor-show.window="open = true; processName = $event.detail?.processName ?? ''; variables = []; loading = true; error = ''; loadEnv()"
  x-on:env-editor-hide.window="open = false"
  x-show="open"
  x-cloak
  style="display: none"
  role="dialog"
  aria-modal="true"
  aria-labelledby="env-editor-title"
>
  <div class="absolute inset-0 bg-black/60" @click="$dispatch('env-editor-hide')"></div>
  <div class="absolute inset-4 md:inset-10 bg-slate-800 rounded-lg border border-slate-700 flex flex-col">
    <div class="flex justify-between items-center p-4 border-b border-slate-700">
      <h2 id="env-editor-title" class="text-lg font-semibold">Editor .env — <span x-text="processName || '...'"></span></h2>
      <button
        @click="$dispatch('env-editor-hide')"
        class="p-2 rounded hover:bg-slate-700 focus:ring-2 focus:ring-emerald-500"
        aria-label="Chiudi"
      >
        <span class="text-xl">&times;</span>
      </button>
    </div>
    <div class="flex-1 flex flex-col p-4 overflow-auto">
      <p x-show="error" class="text-red-400 text-sm mb-2" x-text="error"></p>
      <template x-if="!loading">
        <div class="space-y-2 font-mono text-sm">
          <template x-for="(row, idx) in variables" :key="idx">
            <div class="flex items-center gap-2 group" :class="{ 'flex-wrap': row.type === 'var' }">
              <template x-if="row.type === 'var'">
                <div class="flex-1 flex items-center gap-2 min-w-0">
                  <span class="text-slate-400 shrink-0" x-text="row.key + '='"></span>
                  <input
                    :type="row.revealed ? 'text' : 'password'"
                    x-model="row.value"
                    class="flex-1 min-w-0 px-2 py-1 bg-slate-900 border border-slate-600 rounded text-slate-200 focus:ring-1 focus:ring-emerald-500"
                  />
                  <button
                    type="button"
                    @click="row.revealed = !row.revealed"
                    class="shrink-0 px-2 py-1 rounded text-xs text-slate-400 hover:text-emerald-400 hover:bg-slate-700"
                    x-text="row.revealed ? 'Nascondi' : 'Rivela'"
                  ></button>
                </div>
              </template>
              <template x-if="row.type === 'comment'">
                <div class="w-full text-slate-500" x-text="row.raw"></div>
              </template>
              <template x-if="row.type === 'empty'">
                <div class="w-full h-2 text-slate-600">&nbsp;</div>
              </template>
            </div>
          </template>
          <p x-show="variables.length === 0 && !loading" class="text-slate-500 py-4">Nessuna variabile. Carica un file .env esistente o aggiungi manualmente.</p>
        </div>
      </template>
      <p x-show="loading" class="text-slate-400 py-4">Caricamento...</p>
    </div>
    <div class="flex gap-2 p-4 border-t border-slate-700 shrink-0">
      <label class="inline-flex items-center gap-2 text-sm text-slate-300">
        <input type="checkbox" x-model="restartAfterSave" class="rounded border-slate-600 bg-slate-700" />
        Riavvia processo dopo il salvataggio
      </label>
      <button
        @click="loadEnv()"
        :disabled="loading"
        class="px-4 py-2 rounded-lg bg-slate-600 hover:bg-slate-500 disabled:opacity-50 disabled:cursor-not-allowed focus:ring-2 focus:ring-emerald-500"
      >
        Carica .env
      </button>
      <button
        @click="validateEnv()"
        :disabled="loading"
        class="px-4 py-2 rounded-lg bg-blue-700 hover:bg-blue-600 disabled:opacity-50 disabled:cursor-not-allowed focus:ring-2 focus:ring-blue-500"
      >
        Valida
      </button>
      <button
        @click="saveEnv()"
        :disabled="saving || loading"
        class="px-4 py-2 rounded-lg bg-emerald-700 hover:bg-emerald-600 disabled:opacity-50 disabled:cursor-not-allowed focus:ring-2 focus:ring-emerald-500"
      >
        Salva Modifiche
      </button>
    </div>
  </div>
</div>

<script>
  function parseEnvContent(text) {
    const lines = (text || '').split(/\r?\n/);
    const result = [];
    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];
      if (line.startsWith('#')) {
        result.push({ type: 'comment', raw: line });
      } else if (/^\s*$/.test(line)) {
        result.push({ type: 'empty', raw: line });
      } else {
        const eq = line.indexOf('=');
        if (eq >= 0) {
          const key = line.substring(0, eq).trim();
          const value = line.substring(eq + 1);
          result.push({ type: 'var', key, value, revealed: false });
        } else {
          result.push({ type: 'comment', raw: line });
        }
      }
    }
    return result;
  }

  function buildEnvContent(variables) {
    return variables.map(row => {
      if (row.type === 'var') return row.key + '=' + (row.value ?? '');
      if (row.type === 'comment' || row.type === 'empty') return row.raw ?? '';
      return '';
    }).join('\n');
  }

  function envEditorModal() {
    return {
      open: false,
      processName: '',
      variables: [],
      loading: false,
      saving: false,
      restartAfterSave: false,
      originalContent: '',
      error: '',
      loadEnv() {
        const name = this.processName;
        if (!name) return;
        this.loading = true;
        this.error = '';
        fetch(`/api/env/${encodeURIComponent(name)}`)
          .then(r => r.json())
          .then(d => {
            const content = d.content ?? '';
            this.variables = content ? parseEnvContent(content) : [];
            this.originalContent = content ? content.replace(/\r\n/g, '\n').trimEnd() : '';
            this.loading = false;
            if (d.exists === false && !content) this.variables = [];
          })
          .catch(e => {
            this.error = e.message || 'Errore caricamento';
            this.loading = false;
          });
      },
      saveEnv() {
        const name = this.processName;
        if (!name) return;
        const content = buildEnvContent(this.variables);
        if (!content.trim()) {
          this.error = 'Il contenuto non può essere vuoto.';
          return;
        }
        this.saving = true;
        this.error = '';
        fetch(`/api/env/${encodeURIComponent(name)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: content + '\n', restartProcess: this.restartAfterSave }),
        })
          .then(r => r.json())
          .then(d => {
            this.saving = false;
            if (d.ok) {
              const msg = d.restarted ? 'Modifiche salvate e processo riavviato' : 'Modifiche salvate (backup in .env.bak)';
              window.dispatchEvent(new CustomEvent('toast', { detail: { message: msg, type: 'success' } }));
              this.$dispatch('env-editor-hide');
            } else {
              this.error = d.error || 'Errore salvataggio';
            }
          })
          .catch(e => {
            this.error = e.message || 'Errore salvataggio';
            this.saving = false;
          });
      },
      validateEnv() {
        const name = this.processName;
        const content = buildEnvContent(this.variables);
        fetch(`/api/env/validate/${encodeURIComponent(name)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ content, requiredKeys: ['SESSION_SECRET'] }),
        })
          .then((r) => r.json())
          .then((d) => {
            if (!d.ok) throw new Error(d.error || 'Validazione fallita');
            const diffs = this.originalContent !== content.trimEnd();
            const parts = [`Chiavi parse: ${d.parsedKeys}`];
            if (d.missing?.length) parts.push(`Mancanti: ${d.missing.join(', ')}`);
            if (d.warnings?.length) parts.push(`Warning: ${d.warnings.join(' | ')}`);
            parts.push(`Diff: ${diffs ? 'presente' : 'nessuna modifica'}`);
            window.dispatchEvent(new CustomEvent('toast', { detail: { message: parts.join(' • '), type: d.missing?.length ? 'error' : 'info' } }));
          })
          .catch((e) => {
            window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore validazione: ' + e.message, type: 'error' } }));
          });
      },
    };
  }
</script>
