  let sysProcessesData = [];
  let sysProcessesSort = { col: 'memRss', dir: -1 };

  function renderSysProcessesRow(p) {
    const detail = p.detail ? '<span class="text-emerald-400/90">' + escapeHtml(p.detail) + '</span>' : '<span class="text-slate-500">—</span>';
    return '<tr class="border-t border-slate-700 hover:bg-slate-700/30">' +
