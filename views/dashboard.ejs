  // Chart.js - CPU e RAM (scala fissa 0-100%), colori da CSS variables (tema light/dark)
  function crChartTokens() {
    const st = getComputedStyle(document.documentElement);
    return {
      grid: st.getPropertyValue('--cr-chart-grid').trim() || 'rgba(148, 163, 184, 0.2)',
      tick: st.getPropertyValue('--cr-chart-tick').trim() || '#64748b',
      cpu: st.getPropertyValue('--cr-chart-cpu').trim(),
      cpuFill: st.getPropertyValue('--cr-chart-cpu-fill').trim(),
      ram: st.getPropertyValue('--cr-chart-ram').trim(),
      ramFill: st.getPropertyValue('--cr-chart-ram-fill').trim(),
    };
  }

  function buildChartOptions(t) {
    const chartScale100 = {
      min: 0,
      max: 100,
      grid: { color: t.grid },
      ticks: { color: t.tick, stepSize: 25 }
    };
    return {
      responsive: true,
      maintainAspectRatio: true,
      plugins: { legend: { display: false } },
      scales: {
        x: {
          grid: { color: t.grid },
          ticks: { color: t.tick, maxTicksLimit: 8 }
        },
        y: chartScale100
      }
    };
  }

  const t0 = crChartTokens();
  const chartCpu = new Chart(document.getElementById('chartCpu'), {
    type: 'line',
    options: buildChartOptions(t0),
    data: { labels: [], datasets: [{ label: 'CPU %', data: [], borderColor: t0.cpu, backgroundColor: t0.cpuFill, fill: true }] }
  });
  const chartRam = new Chart(document.getElementById('chartRam'), {
    type: 'line',
    options: buildChartOptions(t0),
    data: { labels: [], datasets: [{ label: 'RAM %', data: [], borderColor: t0.ram, backgroundColor: t0.ramFill, fill: true }] }
  });

  function applyChartTheme() {
    const t = crChartTokens();
    [chartCpu, chartRam].forEach((ch) => {
      const ds = ch.data.datasets[0];
      if (ch === chartCpu) {
        ds.borderColor = t.cpu;
        ds.backgroundColor = t.cpuFill;
      } else {
        ds.borderColor = t.ram;
        ds.backgroundColor = t.ramFill;
      }
      ch.options.scales.x.grid.color = t.grid;
      ch.options.scales.x.ticks.color = t.tick;
      ch.options.scales.y.grid.color = t.grid;
      ch.options.scales.y.ticks.color = t.tick;
      ch.update('none');
    });
  }
  window.addEventListener('cr-theme-change', applyChartTheme);

  function setChartFromHistory(chart, labels, values) {
    chart.data.labels = labels.slice();
    chart.data.datasets[0].data = values.slice();
    chart.update('none');
  }

  function appendChartPoint(chart, label, value) {
    chart.data.labels.push(label);
    chart.data.datasets[0].data.push(value);
    const maxPoints = 100;
    if (chart.data.labels.length > maxPoints) {
      chart.data.labels.shift();
      chart.data.datasets[0].data.shift();
    }
    chart.update('none');
  }

  async function fetchStats() {
    try {
      const res = await fetch('/api/system/stats');
      const data = await res.json();
      if (data.cpuPercent === undefined) return;
      const ramVal = data.memoryPercent ?? (data.memoryTotalMB ? (data.memoryUsedMB / data.memoryTotalMB) * 100 : 0);
      const now = new Date().toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      if (data.history && data.history.labels && data.history.labels.length > 0) {
        setChartFromHistory(chartCpu, data.history.labels, data.history.cpu);
        setChartFromHistory(chartRam, data.history.labels, data.history.ram);
        if (data.history.labels[data.history.labels.length - 1] !== now) {
          appendChartPoint(chartCpu, now, data.cpuPercent);
          appendChartPoint(chartRam, now, ramVal);
        }
      } else {
        appendChartPoint(chartCpu, now, data.cpuPercent);
        appendChartPoint(chartRam, now, ramVal);
      }
    } catch (_) {}
  }

