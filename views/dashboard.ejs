  async function loadSystem() {
    try {
      const [sysRes, nginxRes, redisRes] = await Promise.all([fetch('/api/system'), fetch('/api/nginx-status'), fetch('/api/redis-health')]);
      const sys = await sysRes.json();
      const nginx = await nginxRes.json();
