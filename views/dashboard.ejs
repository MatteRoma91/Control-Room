</section>

<section class="mb-8" aria-labelledby="quality-heading">
  <h2 id="quality-heading" class="text-lg font-semibold text-slate-200 mb-3">Quality gates</h2>
  <div id="qualityGatesBox" class="rounded-lg border border-slate-700 bg-slate-800 p-4 text-sm text-slate-300">Caricamento KPI operativi...</div>
</section>

<!-- Processi PM2 (aggiornamento live ogni 3s) -->
<section class="mb-8" aria-labelledby="processes-heading">
  <h2 id="processes-heading" class="text-lg font-semibold text-slate-200 mb-4 flex items-center gap-2">
    Processi PM2
    <span id="pm2LiveIndicator" class="inline-flex items-center gap-1 text-xs font-normal text-slate-500">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
      <span>live</span>
    </span>
  </h2>
  <div id="processCardsMobile" class="md:hidden space-y-3">
    <% (processes || []).forEach((p) => { %>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <a href="/process/<%= p.name %>" class="text-emerald-400 hover:underline font-mono font-medium block mb-2"><%= p.name %></a>
      <div class="flex flex-wrap gap-2 text-sm text-slate-400 mb-3">
        <span class="px-2 py-0.5 rounded text-xs font-medium <%= p.status === 'online' ? 'bg-emerald-900/60 text-emerald-300' : p.status === 'stopped' ? 'bg-amber-900/60 text-amber-300' : 'bg-red-900/60 text-red-300' %>"><%= p.status %></span>
        <span>CPU <%= p.cpu %>%</span>
        <span><%= p.memory %> MB</span>
        <span>Uptime <%= p.uptime %></span>
        <span>Restart <%= p.restart_time %></span>
        <% if (p.restart_time >= 3) { %>
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-red-900/60 text-red-300">Crash loop?</span>
        <% } %>
      </div>
      <div class="flex flex-wrap gap-1">
        <button onclick="processAction('<%= p.name %>', 'start', this)" class="px-2 py-1.5 rounded text-xs bg-emerald-700 hover:bg-emerald-600 min-h-[36px] disabled:opacity-50 disabled:cursor-not-allowed">Start</button>
        <button onclick="processAction('<%= p.name %>', 'stop', this)" class="px-2 py-1.5 rounded text-xs bg-amber-700 hover:bg-amber-600 min-h-[36px] disabled:opacity-50 disabled:cursor-not-allowed">Stop</button>
        <button onclick="processAction('<%= p.name %>', 'restart', this)" class="px-2 py-1.5 rounded text-xs bg-blue-700 hover:bg-blue-600 min-h-[36px] disabled:opacity-50 disabled:cursor-not-allowed">Restart</button>
        <% if (!p.isModule) { %><button onclick="processFlush('<%= p.name %>', this)" class="px-2 py-1.5 rounded text-xs bg-slate-600 hover:bg-slate-500 min-h-[36px] disabled:opacity-50 disabled:cursor-not-allowed">Flush</button><% } %>
        <button onclick="resetRestartCount('<%= p.name %>', this)" class="px-2 py-1.5 rounded text-xs bg-slate-600 hover:bg-slate-500 min-h-[36px] disabled:opacity-50 disabled:cursor-not-allowed" title="Azzera contatore restart">Azzera restart</button>
      </div>
    </div>
    <% }); %>
    <% if (!processes || processes.length === 0) { %>
    <p class="text-slate-500 text-center py-8">Nessun processo PM2</p>
    <% } %>
  </div>
  <div class="hidden md:block rounded-lg border border-slate-700 bg-slate-800">
    <table class="w-full">
      <thead class="bg-slate-700/50">
        <tr>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Nome</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Status</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">CPU %</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Memory</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Uptime</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Restarts</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Azioni</th>
        </tr>
      </thead>
      <tbody id="processTableBody">
        <% (processes || []).forEach((p) => { %>
          <tr class="border-t border-slate-700 hover:bg-slate-700/30">
            <td class="px-4 py-3 font-mono">
              <a href="/process/<%= p.name %>" class="text-emerald-400 hover:underline"><%= p.name %></a>
            </td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 rounded text-xs font-medium <%= p.status === 'online' ? 'bg-emerald-900/60 text-emerald-300' : p.status === 'stopped' ? 'bg-amber-900/60 text-amber-300' : 'bg-red-900/60 text-red-300' %>">
                <%= p.status %>
              </span>
            </td>
            <td class="px-4 py-3"><%= p.cpu %>%</td>
            <td class="px-4 py-3"><%= p.memory %> MB</td>
            <td class="px-4 py-3"><%= p.uptime %></td>
            <td class="px-4 py-3">
              <%= p.restart_time %>
              <% if (p.restart_time >= 3) { %>
                <span class="ml-2 px-2 py-0.5 rounded text-[11px] font-medium bg-red-900/60 text-red-300 whitespace-nowrap">Crash loop?</span>
              <% } %>
            </td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1">
                <button onclick="processAction('<%= p.name %>', 'start', this)" class="px-2 py-1 rounded text-xs bg-emerald-700 hover:bg-emerald-600 disabled:opacity-50 disabled:cursor-not-allowed">Start</button>
                <button onclick="processAction('<%= p.name %>', 'stop', this)" class="px-2 py-1 rounded text-xs bg-amber-700 hover:bg-amber-600 disabled:opacity-50 disabled:cursor-not-allowed">Stop</button>
                <button onclick="processAction('<%= p.name %>', 'restart', this)" class="px-2 py-1 rounded text-xs bg-blue-700 hover:bg-blue-600 disabled:opacity-50 disabled:cursor-not-allowed">Restart</button>
                <% if (!p.isModule) { %><button onclick="processFlush('<%= p.name %>', this)" class="px-2 py-1 rounded text-xs bg-slate-600 hover:bg-slate-500 disabled:opacity-50 disabled:cursor-not-allowed">Flush</button><% } %>
                <button onclick="resetRestartCount('<%= p.name %>', this)" class="px-2 py-1 rounded text-xs bg-slate-600 hover:bg-slate-500 disabled:opacity-50 disabled:cursor-not-allowed" title="Azzera contatore restart">Azzera restart</button>
              </div>
            </td>
          </tr>
        <% }); %>
        <% if (!processes || processes.length === 0) { %>
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-slate-500">Nessun processo PM2</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<!-- Processi di sistema (top 25 per CPU) -->
<section class="mb-8" aria-labelledby="sysprocesses-heading">
  <div class="flex flex-wrap items-center gap-4 mb-4">
    <div>
      <h2 id="sysprocesses-heading" class="text-lg font-semibold text-slate-200">Processi di sistema</h2>
      <p class="text-sm text-slate-400 mt-1">Top 25 processi per RAM (nginx, node, systemd, ecc.)</p>
    </div>
    <button
      onclick="loadSystemProcesses(this)"
      class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900"
    >
      Aggiorna processi sistema
    </button>
  </div>
  <div id="sysProcessesContainer" class="hidden">
    <div class="rounded-lg border border-slate-700 bg-slate-800 overflow-x-auto">
      <table class="w-full min-w-[500px]">
        <thead class="bg-slate-700/50">
          <tr>
            <th data-sort="pid" onclick="sortSysProcessesBy('pid')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">PID <span class="sort-indicator"></span></th>
            <th data-sort="name" onclick="sortSysProcessesBy('name')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">Nome <span class="sort-indicator"></span></th>
            <th data-sort="detail" onclick="sortSysProcessesBy('detail')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">Dettaglio <span class="sort-indicator"></span></th>
            <th data-sort="cpu" onclick="sortSysProcessesBy('cpu')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">CPU % <span class="sort-indicator"></span></th>
            <th data-sort="memRss" onclick="sortSysProcessesBy('memRss')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">RAM (MB) <span class="sort-indicator"></span></th>
            <th data-sort="user" onclick="sortSysProcessesBy('user')" class="text-left px-4 py-3 text-slate-300 font-medium cursor-pointer select-none hover:text-slate-100 hover:bg-slate-700 transition-colors">Utente <span class="sort-indicator"></span></th>
          </tr>
        </thead>
        <tbody id="sysProcessesBody"></tbody>
      </table>
    </div>
  </div>
</section>

<script>
  function showToast(message, type) {
    window.dispatchEvent(new CustomEvent('toast', { detail: { message, type } }));
  }

  function setBtnLoading(btn, loading) {
    if (!btn) return;
    if (loading) {
      btn._originalText = btn.textContent;
      btn.textContent = 'In corso...';
      btn.disabled = true;
    } else {
      btn.textContent = btn._originalText || btn.textContent;
      btn.disabled = false;
    }
  }

  async function getConfirmPhrase(title, message, expectedPhrase) {
    const result = await requestStrongConfirm({ title, message, expectedPhrase });
    if (!result || !result.ok) return null;
    return result.confirmPhrase;
  }

  async function processAction(name, action, btn) {
    let confirmPhrase = '';
    if (action === 'stop' || action === 'restart') {
      const expected = `${action.toUpperCase()}:${name}`;
      const phrase = await getConfirmPhrase(
        'Conferma azione ad alto rischio',
        `Stai per eseguire ${action.toUpperCase()} su ${name}.`,
        expected
      );
      if (!phrase) return;
      confirmPhrase = phrase;
    }
    setBtnLoading(btn, true);
    try {
      const res = await fetch(`/api/process/${action}/${encodeURIComponent(name)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirmPhrase }),
      });
      const data = await res.json();
      if (data.ok) {
        showToast('Operazione completata', 'success');
        await loadProcessesLive();
      } else {
        showToast('Errore: ' + (data.error || 'Operazione fallita'), 'error');
        setBtnLoading(btn, false);
      }
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
      setBtnLoading(btn, false);
    }
  }

  async function processFlush(name, btn) {
    setBtnLoading(btn, true);
    try {
      const res = await fetch(`/api/process/flush/${encodeURIComponent(name)}`, { method: 'POST' });
      const data = await res.json();
      if (data.ok) {
        showToast('Log svuotati', 'success');
        setTimeout(() => location.reload(), 500);
      } else {
        showToast('Errore: ' + (data.error || 'Flush fallito'), 'error');
        setBtnLoading(btn, false);
      }
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
      setBtnLoading(btn, false);
    }
  }

  async function gitPull(name, btn) {
    setBtnLoading(btn, true);
    window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output: '', loading: true } }));
    try {
      const res = await fetch(`/api/process/git-pull/${encodeURIComponent(name)}`, { method: 'POST' });
      const data = await res.json();
      const output = (data.output || data.error || '').trim() || (data.ok ? 'Git pull e restart completati.' : 'Operazione fallita.');
      window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output, loading: false } }));
      setBtnLoading(btn, false);
      if (data.ok) {
        showToast('Deployment completato', 'success');
        setTimeout(() => location.reload(), 1000);
      }
    } catch (e) {
      setBtnLoading(btn, false);
      window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output: 'Errore: ' + e.message, loading: false } }));
      showToast('Errore: ' + e.message, 'error');
    }
  }

  async function resetRestartCount(name, btn) {
    setBtnLoading(btn, true);
    try {
      const res = await fetch(`/api/process/reset/${encodeURIComponent(name)}`, { method: 'POST' });
      const data = await res.json();
      if (data.ok) {
        showToast('Contatore restart azzerato', 'success');
        setTimeout(() => location.reload(), 500);
      } else {
        showToast('Errore: ' + (data.error || 'Operazione fallita'), 'error');
        setBtnLoading(btn, false);
      }
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
      setBtnLoading(btn, false);
    }
  }

  async function loadSystem() {
    try {
      const [sysRes, nginxRes] = await Promise.all([fetch('/api/system'), fetch('/api/nginx-status')]);
      const sys = await sysRes.json();
      const nginx = await nginxRes.json();
      if (sys.uptime !== undefined) {
        document.getElementById('sysUptime').textContent = sys.uptime;
        document.getElementById('sysCpu').textContent = sys.loadAvg1;
        document.getElementById('sysMem').textContent = sys.memoryUsedMB + ' / ' + sys.memoryTotalMB + ' MB (' + sys.memoryPercent + '%)';
        document.getElementById('sysDisk').textContent = sys.diskUsedGB + ' / ' + sys.diskTotalGB + ' GB (' + sys.diskPercent + '%)';
      }
      document.getElementById('nginxStatus').textContent = 'Nginx: ' + (nginx.active ? 'attivo' : 'non attivo');
    } catch (e) {
      document.getElementById('sysUptime').textContent = 'Errore';
    }
  }

  function formatBindAddresses(addrs) {
    if (!addrs || addrs.length === 0) return '—';
    const short = addrs.map(function (a) {
      if (a === '0.0.0.0' || a === '*' || a === '[::]') return 'tutte le interfacce';
      if (a === '127.0.0.1' || a === '[::1]') return 'solo localhost';
      return a;
    });
    return [...new Set(short)].join(', ');
  }

  function renderSitePorts(data) {
    const tbody = document.getElementById('sitePortsBody');
    const mobile = document.getElementById('sitePortsMobile');
    const warn = document.getElementById('sitePortsSsWarn');
    if (warn) {
      if (data.ssOk === false && data.ssError) {
        warn.textContent = 'Impossibile eseguire ss: ' + data.ssError + '. Lo stato "in ascolto" non è disponibile.';
        warn.classList.remove('hidden');
      } else {
        warn.classList.add('hidden');
      }
    }
    const rows = data.sites || [];
    function listenBadge(listening) {
      if (listening === true) return '<span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-900/60 text-emerald-300">Sì</span>';
      if (listening === false) return '<span class="px-2 py-0.5 rounded text-xs font-medium bg-red-900/60 text-red-300">No</span>';
      return '<span class="text-slate-500">n/d</span>';
    }
    function kindLabel(kind) {
      return kind === 'proxy' ? '<span class="text-slate-500 text-xs ml-1">(proxy)</span>' : '';
    }
    if (tbody) {
      tbody.innerHTML = rows.map(function (s) {
        const urlCell = s.url ? '<a href="' + escapeHtml(s.url) + '" class="text-emerald-400 hover:underline break-all text-sm" target="_blank" rel="noopener">' + escapeHtml(s.url) + '</a>' : '<span class="text-slate-500">—</span>';
        const pm2Cell = s.pm2 ? '<span class="font-mono text-sm">' + escapeHtml(s.pm2) + '</span>' : '<span class="text-slate-500">—</span>';
        const procHint = (s.processHints && s.processHints.length) ? '<div class="text-xs text-slate-500 mt-1 truncate max-w-[200px]" title="' + escapeHtml(s.processHints.join(', ')) + '">' + escapeHtml(s.processHints.join(', ')) + '</div>' : '';
        return '<tr class="border-t border-slate-700 hover:bg-slate-700/30">' +
          '<td class="px-4 py-3 text-slate-200">' + escapeHtml(s.name) + kindLabel(s.kind) + '</td>' +
          '<td class="px-4 py-3">' + urlCell + '</td>' +
          '<td class="px-4 py-3 font-mono text-emerald-300">' + escapeHtml(String(s.port)) + '</td>' +
          '<td class="px-4 py-3">' + pm2Cell + '</td>' +
          '<td class="px-4 py-3">' + listenBadge(s.listening) + procHint + '</td>' +
          '<td class="px-4 py-3 text-sm text-slate-400">' + escapeHtml(formatBindAddresses(s.bindAddresses)) + '</td></tr>';
      }).join('');
    }
    if (mobile) {
      mobile.innerHTML = rows.map(function (s) {
        const urlLine = s.url ? '<a href="' + escapeHtml(s.url) + '" class="text-emerald-400 hover:underline break-all text-sm" target="_blank" rel="noopener">' + escapeHtml(s.url) + '</a>' : '<span class="text-slate-500 text-sm">—</span>';
        return '<div class="rounded-lg border border-slate-700 bg-slate-800 p-4">' +
          '<div class="font-medium text-slate-200 mb-2">' + escapeHtml(s.name) + (s.kind === 'proxy' ? ' <span class="text-slate-500 text-xs">(proxy)</span>' : '') + '</div>' +
          '<div class="space-y-1 text-sm text-slate-400"><div>Porta <span class="font-mono text-emerald-300">' + escapeHtml(String(s.port)) + '</span></div>' +
          '<div>' + urlLine + '</div>' +
          (s.pm2 ? '<div>PM2 <span class="font-mono">' + escapeHtml(s.pm2) + '</span></div>' : '') +
          '<div class="pt-2">' + (s.listening === true ? '<span class="text-emerald-300">In ascolto</span>' : s.listening === false ? '<span class="text-red-400">Non in ascolto</span>' : '<span class="text-slate-500">Stato n/d</span>') + '</div>' +
          '<div class="text-xs">' + escapeHtml(formatBindAddresses(s.bindAddresses)) + '</div></div></div>';
      }).join('');
    }
  }

