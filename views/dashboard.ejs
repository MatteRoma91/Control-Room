<% if (typeof error !== 'undefined' && error) { %>
  <div class="mb-4 p-4 bg-red-900/50 border border-red-700 rounded-lg text-red-200" role="alert">
    Errore: <%= error %>
  </div>
<% } %>

<section class="mb-6" aria-labelledby="incident-heading">
  <div id="incidentBanner" class="hidden rounded-lg border p-4">
    <div class="flex items-center justify-between gap-2">
      <div>
        <h2 id="incident-heading" class="text-lg font-semibold">Incident center</h2>
        <p id="incidentText" class="text-sm text-slate-300 mt-1"></p>
      </div>
      <a href="/audit" class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-sm">Apri audit</a>
    </div>
  </div>
</section>

<!-- Grafici CPU e RAM (scala 0-100%) -->
<section class="mb-8" aria-labelledby="charts-heading">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
    <h2 id="charts-heading" class="text-lg font-semibold text-slate-200">Risorse Server (Real-time)</h2>
    <button
      id="btnRefreshAll"
      onclick="refreshAllTables(this)"
      class="px-4 py-2 rounded-lg bg-emerald-700 hover:bg-emerald-600 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900 flex items-center gap-2"
      aria-label="Aggiorna tutte le tabelle"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Aggiorna tutto
    </button>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <h3 class="text-sm text-slate-400 mb-2">CPU % (0–100)</h3>
      <canvas id="chartCpu" height="120"></canvas>
    </div>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <h3 class="text-sm text-slate-400 mb-2">RAM % (0–100)</h3>
      <canvas id="chartRam" height="120"></canvas>
    </div>
  </div>
</section>

<!-- Overview Server -->
<section class="mb-8" aria-labelledby="overview-heading">
  <h2 id="overview-heading" class="text-lg font-semibold text-slate-200 mb-4">Overview Server</h2>
  <div id="systemOverview" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <div class="text-sm text-slate-400">Uptime</div>
      <div id="sysUptime" class="text-lg font-mono">-</div>
    </div>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <div class="text-sm text-slate-400">Load 1m</div>
      <div id="sysCpu" class="text-lg font-mono">-</div>
    </div>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <div class="text-sm text-slate-400">RAM</div>
      <div id="sysMem" class="text-lg font-mono">-</div>
    </div>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
      <div class="text-sm text-slate-400">Disco</div>
      <div id="sysDisk" class="text-lg font-mono">-</div>
    </div>
  </div>
  <div class="flex flex-wrap gap-4 items-center">
    <span id="nginxStatus" class="text-sm text-slate-400">Nginx: -</span>
    <button
      id="btnNginxReload"
      onclick="nginxReload(this)"
      class="px-3 py-1.5 rounded text-sm bg-slate-700 hover:bg-slate-600 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900"
      aria-label="Ricarica configurazione Nginx"
    >
      Reload Nginx
    </button>
  </div>
</section>

<!-- Azioni globali -->
<section class="mb-8" aria-labelledby="global-actions-heading">
  <h2 id="global-actions-heading" class="text-lg font-semibold text-slate-200 mb-4">Azioni globali</h2>
  <div class="flex flex-wrap gap-4">
    <button
      onclick="restartAllWebapps(this)"
      class="px-4 py-2 rounded-lg bg-blue-700 hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-slate-900 disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Riavvia tutte le webapp
    </button>
    <button
      onclick="restoreAll(this)"
      class="px-4 py-2 rounded-lg bg-emerald-700 hover:bg-emerald-600 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900 disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Ripristina tutti i processi
    </button>
    <button
      onclick="runRecoverRunbook('padel-tour', this)"
      class="px-4 py-2 rounded-lg bg-purple-700 hover:bg-purple-600 focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-900 disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Runbook Recovery (padel-tour)
    </button>
  </div>
</section>

<!-- Porte siti -->
<section class="mb-8" aria-labelledby="ports-heading">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
    <div>
      <h2 id="ports-heading" class="text-lg font-semibold text-slate-200">Porte in ascolto</h2>
      <p class="text-sm text-slate-400 mt-1">Webapp (backend Node) e Nginx 80/443; stato rilevato con <span class="font-mono text-slate-300">ss</span> sul server.</p>
