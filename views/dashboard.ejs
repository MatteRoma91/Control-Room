      '<td class="px-4 py-2 text-slate-400">' + escapeHtml(p.user) + '</td></tr>';
  }

  function renderSysProcessesTable(processes, emptyMsg) {
    const tbody = document.getElementById('sysProcessesBody');
    if (!tbody) return;
    if (!processes || processes.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-6 text-center text-slate-500">' + escapeHtml(emptyMsg || 'Nessun dato') + '</td></tr>';
      document.querySelectorAll('#sysProcessesContainer th[data-sort] .sort-indicator').forEach(function (s) { s.textContent = ''; s.className = 'sort-indicator'; });
      return;
    }
    const sorted = [...processes].sort(function (a, b) {
      const col = sysProcessesSort.col || 'cpu';
      const dir = sysProcessesSort.dir;
      let va, vb;
      switch (col) {
        case 'pid': va = Number(a.pid); vb = Number(b.pid); break;
        case 'cpu': va = parseFloat(String(a.cpu)) || 0; vb = parseFloat(String(b.cpu)) || 0; break;
        case 'memRss': va = Number(a.memRss) || 0; vb = Number(b.memRss) || 0; break;
        case 'name': va = (a.name || '').toLowerCase(); vb = (b.name || '').toLowerCase(); break;
        case 'detail': va = (a.detail || '').toLowerCase(); vb = (b.detail || '').toLowerCase(); break;
        case 'user': va = (a.user || '').toLowerCase(); vb = (b.user || '').toLowerCase(); break;
        default: return 0;
      }
      if (va < vb) return -1 * dir;
      if (va > vb) return 1 * dir;
      return 0;
    });
    tbody.innerHTML = sorted.map(renderSysProcessesRow).join('');
    document.querySelectorAll('#sysProcessesContainer th[data-sort]').forEach(function (th) {
      const span = th.querySelector('.sort-indicator');
      if (!span) return;
      if (th.dataset.sort === sysProcessesSort.col) {
        span.textContent = sysProcessesSort.dir === 1 ? ' ▲' : ' ▼';
        span.className = 'sort-indicator text-emerald-400';
      } else {
        span.textContent = '';
        span.className = 'sort-indicator';
      }
    });
  }

  function sortSysProcessesBy(col) {
    if (sysProcessesSort.col === col) {
      sysProcessesSort.dir = sysProcessesSort.dir === 1 ? -1 : 1;
    } else {
      sysProcessesSort.col = col;
      sysProcessesSort.dir = 1;
    }
    renderSysProcessesTable(sysProcessesData);
  }

  async function updateProcessTable(processes) {
    const tbody = document.getElementById('processTableBody');
    const cards = document.getElementById('processCardsMobile');
    if (!tbody || !cards) return;
    if (!processes || processes.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="px-4 py-8 text-center text-slate-500">Nessun processo PM2</td></tr>';
      cards.innerHTML = '<p class="text-slate-500 text-center py-8">Nessun processo PM2</p>';
      return;
    }
    tbody.innerHTML = processes.map(renderProcessRow).join('');
    cards.innerHTML = processes.map(renderProcessCard).join('');
  }

  async function loadProcessesLive() {
    try {
      const res = await fetch('/api/processes');
      const data = await res.json();
      if (data.processes) updateProcessTable(data.processes);
    } catch (_) {}
  }

  async function loadSystemProcesses(btn) {
    setBtnLoading(btn, true);
    try {
      const res = await fetch('/api/system/processes');
      const data = await res.json();
      const container = document.getElementById('sysProcessesContainer');
      if (!container) return;
      if (data.error || !data.processes || data.processes.length === 0) {
        sysProcessesData = [];
        renderSysProcessesTable([], data.error || 'Nessun dato');
      } else {
        sysProcessesData = data.processes;
        sysProcessesSort = { col: 'memRss', dir: -1 };
        renderSysProcessesTable(sysProcessesData);
      }
      container.classList.remove('hidden');
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
    }
    setBtnLoading(btn, false);
  }

  loadSystem();
  loadIncidentSummary();
  loadSitePorts();
  loadQualityGates();
  fetchStats();
  loadProcessesLive();
  setInterval(fetchStats, 3000);
  setInterval(loadProcessesLive, 3000);
  setInterval(loadIncidentSummary, 10000);
  setInterval(loadQualityGates, 20000);
</script>
