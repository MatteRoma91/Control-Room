    Errore: <%= error %>
  </div>
<% } %>

<p class="text-sm text-cr-muted mb-6 max-w-3xl">Console operativa: stato dei servizi, azioni su PM2 e strumenti di diagnostica. Su mobile usa le azioni rapide qui sotto per i collegamenti più usati.</p>

