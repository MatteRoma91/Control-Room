<!-- Processi di sistema (top 25 per CPU) -->
<section class="mb-8" aria-labelledby="sysprocesses-heading">
  <div class="flex flex-wrap items-center gap-4 mb-4">
    <div>
      <h2 id="sysprocesses-heading" class="text-lg font-semibold text-cr-text">Processi di sistema</h2>
      <p class="text-sm text-cr-muted mt-1">Top 25 processi per RAM (nginx, node, systemd, ecc.)</p>
    </div>
    <button
      onclick="loadSystemProcesses(this)"
      class="px-4 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-canvas"
    >
      Aggiorna processi sistema
    </button>
  </div>
  <div id="sysProcessesContainer" class="hidden">
    <div class="rounded-lg border border-cr-border bg-cr-surface overflow-x-auto">
      <table class="w-full min-w-[500px]">
        <thead class="cr-thead">
          <tr>
            <th data-sort="pid" onclick="sortSysProcessesBy('pid')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">PID <span class="sort-indicator"></span></th>
            <th data-sort="name" onclick="sortSysProcessesBy('name')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">Nome <span class="sort-indicator"></span></th>
            <th data-sort="detail" onclick="sortSysProcessesBy('detail')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">Dettaglio <span class="sort-indicator"></span></th>
            <th data-sort="cpu" onclick="sortSysProcessesBy('cpu')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">CPU % <span class="sort-indicator"></span></th>
            <th data-sort="memRss" onclick="sortSysProcessesBy('memRss')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">RAM (MB) <span class="sort-indicator"></span></th>
            <th data-sort="user" onclick="sortSysProcessesBy('user')" class="text-left px-4 py-3 text-cr-text font-medium cursor-pointer select-none hover:text-cr-text hover:bg-cr-surface2 transition-colors">Utente <span class="sort-indicator"></span></th>
          </tr>
        </thead>
        <tbody id="sysProcessesBody"></tbody>
      </table>
    </div>
  </div>
</section>

<script>
  function showToast(message, type, duration) {
    window.dispatchEvent(new CustomEvent('toast', { detail: { message, type, duration } }));
  }

  function setBtnLoading(btn, loading) {
    if (!btn) return;
    if (loading) {
      btn._originalText = btn.textContent;
      btn.textContent = 'In corso…';
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
    } else {
      btn.textContent = btn._originalText || btn.textContent;
      btn.disabled = false;
      btn.removeAttribute('aria-busy');
    }
  }

  async function getConfirmPhrase(title, message, expectedPhrase) {
    const result = await requestStrongConfirm({ title, message, expectedPhrase });
    if (!result || !result.ok) return null;
    return result.confirmPhrase;
  }

  async function processAction(name, action, btn) {
    let confirmPhrase = '';
    if (action === 'stop' || action === 'restart') {
      const expected = `${action.toUpperCase()}:${name}`;
      const phrase = await getConfirmPhrase(
        'Conferma azione ad alto rischio',
        `Stai per eseguire ${action.toUpperCase()} su ${name}.`,
        expected
      );
      if (!phrase) return;
      confirmPhrase = phrase;
    }
    setBtnLoading(btn, true);
    try {
      const res = await fetch(`/api/process/${action}/${encodeURIComponent(name)}`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ confirmPhrase }),
      });
      const text = await res.text();
      let data = {};
      try {
        data = text ? JSON.parse(text) : {};
      } catch (_) {
        showToast(/login/i.test(text.slice(0, 200)) ? 'Sessione scaduta: effettua di nuovo il login.' : 'Risposta non valida (HTTP ' + res.status + ').', 'error');
        setBtnLoading(btn, false);
        return;
      }
      if (data.ok) {
        var doneVerb = action === 'start' ? 'avviato' : action === 'stop' ? 'fermato' : action === 'restart' ? 'riavviato' : 'eseguito';
        showToast('Processo «' + name + '»: ' + doneVerb + ' con successo.', 'success', 5600);
        await loadProcessesLive();
      } else {
        showToast('Errore: ' + (data.error || 'Operazione fallita'), 'error');
        setBtnLoading(btn, false);
      }
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
      setBtnLoading(btn, false);
    }
  }

  async function processFlush(name, btn) {
    setBtnLoading(btn, true);
    try {
      const res = await fetch(`/api/process/flush/${encodeURIComponent(name)}`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      const text = await res.text();
      let data = {};
      try {
        data = text ? JSON.parse(text) : {};
      } catch (_) {
        showToast(/login/i.test(text.slice(0, 200)) ? 'Sessione scaduta: effettua di nuovo il login.' : 'Risposta non valida (HTTP ' + res.status + ').', 'error');
        setBtnLoading(btn, false);
        return;
      }
      if (data.ok) {
        showToast('Log svuotati per «' + name + '».', 'success', 5200);
        setTimeout(() => location.reload(), 500);
      } else {
        showToast('Errore: ' + (data.error || 'Flush fallito'), 'error');
        setBtnLoading(btn, false);
      }
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
      setBtnLoading(btn, false);
    }
  }

  async function gitPull(name, btn) {
    setBtnLoading(btn, true);
    window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output: '', loading: true } }));
    try {
      const res = await fetch(`/api/process/git-pull/${encodeURIComponent(name)}`, {
        method: 'POST',
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      const text = await res.text();
      let data = {};
      try {
        data = text ? JSON.parse(text) : {};
      } catch (_) {
        setBtnLoading(btn, false);
        window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output: 'Sessione scaduta o risposta non valida.', loading: false } }));
        showToast('Risposta non valida dal server.', 'error');
        return;
      }
      const output = (data.output || data.error || '').trim() || (data.ok ? 'Git pull e restart completati.' : 'Operazione fallita.');
      window.dispatchEvent(new CustomEvent('git-pull-show', { detail: { output, loading: false } }));
      setBtnLoading(btn, false);
      if (data.ok) {
        showToast('Deployment completato', 'success');
        setTimeout(() => location.reload(), 1000);
      }
