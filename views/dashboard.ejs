      if (data.severity === 'critical') {
        banner.classList.add('border-cr-danger', 'bg-[var(--cr-danger-bg)]');
        text.textContent = (data.incidents && data.incidents.length) ? data.incidents.slice(0, 3).join(' | ') : 'Sono presenti anomalie operative.';
      } else {
        banner.classList.add('border-cr-success', 'bg-[var(--cr-success-bg)]');
        text.textContent = 'Nessun incidente critico rilevato. Tutti i servizi principali risultano stabili.';
      }
    } catch (_) {}
  }

  async function loadQualityGates() {
    try {
      const res = await fetch('/api/quality-gates');
      const q = await res.json();
      if (!q.ok) throw new Error(q.error || 'Errore');
      const text = [
        `Severity: ${q.healthSeverity}`,
        `Health failing: ${q.failingHealthChecks}`,
        `Processi offline: ${q.offlineProcesses}`,
        `Audit coverage (azioni critiche): ${q.auditCoverageCriticalActions}%`,
      ].join(' | ');
      document.getElementById('qualityGatesBox').textContent = text;
    } catch (e) {
      document.getElementById('qualityGatesBox').textContent = 'Errore quality gates: ' + e.message;
    }
  }

  function statusClass(status) {
    if (status === 'online') return 'bg-[var(--cr-success-bg)] text-cr-accent';
    if (status === 'stopped') return 'bg-[var(--cr-warning-bg)] text-cr-warning';
    return 'bg-[var(--cr-danger-bg)] text-cr-danger';
  }

  /** Allineare a views/partials/pm2-process-dashboard-card.ejs (instanceSuffix: 'm' | 'd' per id univoci) */
  function pm2CardSafeId(p) {
    return String(p.name || '').replace(/[^a-zA-Z0-9]/g, '_');
  }

  function renderProcessDashboardCard(p, instanceSuffix) {
    const sid = pm2CardSafeId(p);
    const idSuf = instanceSuffix ? '-' + String(instanceSuffix) : '';
    const titleId = 'pm2-card-title-' + sid + idSuf;
    const crashRing = (p.restart_time >= 3) ? ' ring-1 ring-cr-danger/50 border-cr-danger/40' : '';
    const crashCallout = (p.restart_time >= 3)
      ? '<div class="mb-3 rounded-md border border-cr-danger/40 bg-[var(--cr-danger-bg)] px-3 py-2 text-xs font-medium text-cr-danger" role="status">Molti restart di seguito: possibile crash loop. Verifica log e salute del servizio.</div>'
      : '';
    const moduleBadge = p.isModule
      ? '<span class="px-2 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide bg-cr-surface2 text-cr-muted border border-cr-border">Modulo</span>'
      : '';
    const flushBtn = p.isModule ? '' : (
      '<button type="button" onclick="processFlush(\'' + escapeHtml(p.name) + '\', this)" class="px-3 py-2 rounded-lg text-xs font-medium bg-cr-surface2 hover:bg-cr-navHover text-cr-text min-h-[40px] disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface border border-cr-border" title="Svuota log su disco">Flush</button>'
    );
    const n = escapeHtml(p.name);
    return (
      '<article class="rounded-xl border border-cr-border bg-cr-surface p-4 shadow-sm hover:shadow-md transition-shadow focus-within:ring-2 focus-within:ring-cr-accent/30' + crashRing + '" role="region" aria-labelledby="' + titleId + '">' +
      '<header class="flex flex-wrap items-start justify-between gap-2 mb-3 pb-3 border-b border-cr-border">' +
      '<div class="min-w-0 flex-1">' +
      '<h3 id="' + titleId + '" class="font-mono font-semibold text-base text-cr-text truncate">' +
      '<a href="/process/' + encodeURIComponent(p.name) + '" class="text-cr-accent hover:underline">' + n + '</a></h3>' +
      '<p class="text-xs text-cr-muted mt-0.5">Processo PM2</p></div>' +
      '<div class="flex flex-wrap items-center gap-1.5 justify-end shrink-0">' + moduleBadge +
      '<span class="px-2 py-0.5 rounded text-xs font-medium ' + statusClass(p.status) + '">' + escapeHtml(p.status) + '</span></div></header>' +
      crashCallout +
      '<dl class="grid grid-cols-2 gap-x-3 gap-y-2.5 mb-4 text-sm">' +
      '<div><dt class="text-[11px] font-medium uppercase tracking-wide text-cr-muted">CPU</dt>' +
      '<dd class="font-semibold text-cr-text tabular-nums">' + escapeHtml(String(p.cpu)) + '%</dd></div>' +
      '<div><dt class="text-[11px] font-medium uppercase tracking-wide text-cr-muted">Memoria</dt>' +
      '<dd class="font-semibold text-cr-text tabular-nums">' + escapeHtml(String(p.memory)) + ' MB</dd></div>' +
      '<div><dt class="text-[11px] font-medium uppercase tracking-wide text-cr-muted">Uptime</dt>' +
      '<dd class="font-semibold text-cr-text">' + escapeHtml(p.uptime || '—') + '</dd></div>' +
      '<div><dt class="text-[11px] font-medium uppercase tracking-wide text-cr-muted">Restart</dt>' +
      '<dd class="font-semibold text-cr-text tabular-nums">' + escapeHtml(String(p.restart_time)) + '</dd></div></dl>' +
      '<div class="flex flex-col gap-2 pt-1 border-t border-cr-border/80">' +
      '<div class="flex flex-wrap gap-2" role="group" aria-label="Azioni principali">' +
      '<button type="button" onclick="processAction(\'' + escapeHtml(p.name) + '\', \'start\', this)" class="px-3 py-2 rounded-lg text-xs font-medium bg-cr-accent hover:opacity-90 text-white dark:text-slate-900 min-h-[40px] disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface" title="Avvia processo">Start</button>' +
      '<button type="button" onclick="processAction(\'' + escapeHtml(p.name) + '\', \'restart\', this)" class="px-3 py-2 rounded-lg text-xs font-medium bg-cr-info hover:opacity-90 text-white min-h-[40px] disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-info focus:ring-offset-2 focus:ring-offset-cr-surface" title="Riavvia processo">Restart</button></div>' +
      '<div class="flex flex-wrap gap-2" role="group" aria-label="Altre azioni">' +
      '<button type="button" onclick="processAction(\'' + escapeHtml(p.name) + '\', \'stop\', this)" class="px-3 py-2 rounded-lg text-xs font-medium bg-cr-warning hover:opacity-90 text-white dark:text-slate-900 min-h-[40px] disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-warning focus:ring-offset-2 focus:ring-offset-cr-surface" title="Ferma processo">Stop</button>' +
      flushBtn +
      '<button type="button" onclick="resetRestartCount(\'' + escapeHtml(p.name) + '\', this)" class="px-3 py-2 rounded-lg text-xs font-medium bg-cr-surface2 hover:bg-cr-navHover text-cr-text min-h-[40px] disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface border border-cr-border" title="Azzera contatore restart PM2">Azzera restart</button></div></div></article>'
    );
  }

  function escapeHtml(s) {
    if (s == null) return '';
    const d = document.createElement('div');
    d.textContent = String(s);
    return d.innerHTML;
  }

  // Processi di sistema: dati e ordinamento (default per RAM desc)
  let sysProcessesData = [];
  let sysProcessesSort = { col: 'memRss', dir: -1 };

  function renderSysProcessesRow(p) {
    const detail = p.detail ? '<span class="text-cr-accent/90">' + escapeHtml(p.detail) + '</span>' : '<span class="text-cr-muted">—</span>';
    return '<tr class="border-t border-cr-border hover:bg-cr-navHover">' +
      '<td class="px-4 py-2 font-mono text-sm">' + escapeHtml(p.pid) + '</td>' +
      '<td class="px-4 py-2 font-mono text-sm">' + escapeHtml(p.name) + '</td>' +
      '<td class="px-4 py-2 text-sm max-w-[220px] truncate"' + (p.detail && p.detail.length > 35 ? ' title="' + escapeHtml(p.detail) + '"' : '') + '>' + detail + '</td>' +
      '<td class="px-4 py-2">' + escapeHtml(p.cpu) + '%</td>' +
      '<td class="px-4 py-2">' + escapeHtml(p.memRss) + ' MB</td>' +
      '<td class="px-4 py-2 text-cr-muted">' + escapeHtml(p.user) + '</td></tr>';
  }

  function renderSysProcessesTable(processes, emptyMsg) {
    const tbody = document.getElementById('sysProcessesBody');
    if (!tbody) return;
    if (!processes || processes.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-6 text-center text-cr-muted">' + escapeHtml(emptyMsg || 'Nessun dato') + '</td></tr>';
      document.querySelectorAll('#sysProcessesContainer th[data-sort] .sort-indicator').forEach(function (s) { s.textContent = ''; s.className = 'sort-indicator'; });
      return;
    }
    const sorted = [...processes].sort(function (a, b) {
      const col = sysProcessesSort.col || 'cpu';
      const dir = sysProcessesSort.dir;
      let va, vb;
      switch (col) {
        case 'pid': va = Number(a.pid); vb = Number(b.pid); break;
        case 'cpu': va = parseFloat(String(a.cpu)) || 0; vb = parseFloat(String(b.cpu)) || 0; break;
        case 'memRss': va = Number(a.memRss) || 0; vb = Number(b.memRss) || 0; break;
        case 'name': va = (a.name || '').toLowerCase(); vb = (b.name || '').toLowerCase(); break;
        case 'detail': va = (a.detail || '').toLowerCase(); vb = (b.detail || '').toLowerCase(); break;
        case 'user': va = (a.user || '').toLowerCase(); vb = (b.user || '').toLowerCase(); break;
        default: return 0;
      }
      if (va < vb) return -1 * dir;
      if (va > vb) return 1 * dir;
      return 0;
    });
    tbody.innerHTML = sorted.map(renderSysProcessesRow).join('');
    document.querySelectorAll('#sysProcessesContainer th[data-sort]').forEach(function (th) {
      const span = th.querySelector('.sort-indicator');
      if (!span) return;
      if (th.dataset.sort === sysProcessesSort.col) {
        span.textContent = sysProcessesSort.dir === 1 ? ' ▲' : ' ▼';
        span.className = 'sort-indicator text-cr-accent';
      } else {
        span.textContent = '';
        span.className = 'sort-indicator';
      }
    });
  }

  function sortSysProcessesBy(col) {
    if (sysProcessesSort.col === col) {
      sysProcessesSort.dir = sysProcessesSort.dir === 1 ? -1 : 1;
    } else {
      sysProcessesSort.col = col;
      sysProcessesSort.dir = 1;
    }
    renderSysProcessesTable(sysProcessesData);
  }

  async function updateProcessTable(processes) {
    const desktop = document.getElementById('processCardsDesktop');
    const mobile = document.getElementById('processCardsMobile');
    if (!desktop || !mobile) return;
    const emptyMobile = '<p class="text-cr-muted text-center py-8">Nessun processo PM2</p>';
    const emptyDesktop = '<p class="col-span-full text-cr-muted text-center py-10 border border-dashed border-cr-border rounded-xl">Nessun processo PM2</p>';
    if (!processes || processes.length === 0) {
      mobile.innerHTML = emptyMobile;
      desktop.innerHTML = emptyDesktop;
      return;
    }
    mobile.innerHTML = processes.map(function (p) { return renderProcessDashboardCard(p, 'm'); }).join('');
    desktop.innerHTML = processes.map(function (p) { return renderProcessDashboardCard(p, 'd'); }).join('');
  }

  async function loadProcessesLive() {
    try {
      const res = await fetch('/api/processes');
      const data = await res.json();
      if (data.processes) updateProcessTable(data.processes);
    } catch (_) {}
  }

  async function loadSystemProcesses(btn) {
    setBtnLoading(btn, true);
    try {
      const res = await fetch('/api/system/processes');
      const data = await res.json();
      const container = document.getElementById('sysProcessesContainer');
      if (!container) return;
      if (data.error || !data.processes || data.processes.length === 0) {
        sysProcessesData = [];
        renderSysProcessesTable([], data.error || 'Nessun dato');
      } else {
        sysProcessesData = data.processes;
        sysProcessesSort = { col: 'memRss', dir: -1 };
        renderSysProcessesTable(sysProcessesData);
      }
      container.classList.remove('hidden');
    } catch (e) {
      showToast('Errore: ' + e.message, 'error');
    }
    setBtnLoading(btn, false);
  }

  loadSystem();
  loadIncidentSummary();
  loadSitePorts();
  loadQualityGates();
  loadRunbookApps();
  fetchStats();
  loadProcessesLive();
  async function loadPhpServiceCards() {
    try {
      const res = await fetch('/api/health');
      const data = await res.json();
      renderPhpServiceCards(data.results || []);
    } catch (_) {}
  }
  loadPhpServiceCards();
  setInterval(fetchStats, 3000);
  setInterval(loadProcessesLive, 3000);
  setInterval(loadPhpServiceCards, 15000);
  setInterval(loadIncidentSummary, 10000);
  setInterval(loadQualityGates, 20000);
</script>
