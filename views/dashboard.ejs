    >
      Aggiorna porte
    </button>
  </div>
  <p id="sitePortsSsWarn" class="hidden mb-3 text-sm text-amber-400"></p>
  <div id="sitePortsMobile" class="md:hidden space-y-3"></div>
  <div class="hidden md:block rounded-lg border border-slate-700 bg-slate-800 overflow-x-auto">
    <table class="w-full min-w-[640px]">
      <thead class="bg-slate-700/50">
        <tr>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Sito / servizio</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">URL pubblico</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Porta</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">PM2</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">In ascolto</th>
          <th class="text-left px-4 py-3 text-slate-300 font-medium">Indirizzo</th>
        </tr>
      </thead>
      <tbody id="sitePortsBody">
        <tr>
          <td colspan="6" class="px-4 py-6 text-center text-slate-500">Caricamento…</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

