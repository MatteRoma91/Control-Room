      document.getElementById('sysUptime').textContent = 'Errore';
    }
  }

  function formatBindAddresses(addrs) {
    if (!addrs || addrs.length === 0) return '—';
    const short = addrs.map(function (a) {
      if (a === '0.0.0.0' || a === '*' || a === '[::]') return 'tutte le interfacce';
      if (a === '127.0.0.1' || a === '[::1]') return 'solo localhost';
      return a;
    });
    return [...new Set(short)].join(', ');
  }

  function renderSitePorts(data) {
    const tbody = document.getElementById('sitePortsBody');
    const mobile = document.getElementById('sitePortsMobile');
    const warn = document.getElementById('sitePortsSsWarn');
    if (warn) {
      if (data.ssOk === false && data.ssError) {
        warn.textContent = 'Impossibile eseguire ss: ' + data.ssError + '. Lo stato "in ascolto" non è disponibile.';
        warn.classList.remove('hidden');
      } else {
        warn.classList.add('hidden');
      }
    }
    const rows = data.sites || [];
    function listenBadge(listening) {
      if (listening === true) return '<span class="px-2 py-0.5 rounded text-xs font-medium bg-[var(--cr-success-bg)] text-cr-accent">Sì</span>';
      if (listening === false) return '<span class="px-2 py-0.5 rounded text-xs font-medium bg-[var(--cr-danger-bg)] text-cr-danger">No</span>';
      return '<span class="text-cr-muted">n/d</span>';
    }
    function kindLabel(kind) {
      if (kind === 'proxy') return '<span class="text-cr-muted text-xs ml-1">(proxy)</span>';
      if (kind === 'php') return '<span class="text-cr-muted text-xs ml-1">(PHP)</span>';
      return '';
    }
    if (tbody) {
      tbody.innerHTML = rows.map(function (s) {
        const urlCell = s.url ? '<a href="' + escapeHtml(s.url) + '" class="text-cr-accent hover:underline break-all text-sm" target="_blank" rel="noopener">' + escapeHtml(s.url) + '</a>' : '<span class="text-cr-muted">—</span>';
        const pm2Cell = s.pm2 ? '<span class="font-mono text-sm">' + escapeHtml(s.pm2) + '</span>' : '<span class="text-cr-muted">—</span>';
        const portCell = (s.port != null && s.port !== '') ? '<span class="font-mono text-cr-accent">' + escapeHtml(String(s.port)) + '</span>' : (s.portNote ? '<span class="text-cr-muted text-sm">' + escapeHtml(s.portNote) + '</span>' : '<span class="text-cr-muted">—</span>');
        const procHint = (s.processHints && s.processHints.length) ? '<div class="text-xs text-cr-muted mt-1 truncate max-w-[200px]" title="' + escapeHtml(s.processHints.join(', ')) + '">' + escapeHtml(s.processHints.join(', ')) + '</div>' : '';
        return '<tr class="border-t border-cr-border hover:bg-cr-navHover">' +
          '<td class="px-4 py-3 text-cr-text">' + escapeHtml(s.name) + kindLabel(s.kind) + '</td>' +
          '<td class="px-4 py-3">' + urlCell + '</td>' +
          '<td class="px-4 py-3">' + portCell + '</td>' +
          '<td class="px-4 py-3">' + pm2Cell + '</td>' +
          '<td class="px-4 py-3">' + listenBadge(s.listening) + procHint + '</td>' +
          '<td class="px-4 py-3 text-sm text-cr-muted">' + escapeHtml(formatBindAddresses(s.bindAddresses)) + '</td></tr>';
      }).join('');
    }
    if (mobile) {
      mobile.innerHTML = rows.map(function (s) {
        const urlLine = s.url ? '<a href="' + escapeHtml(s.url) + '" class="text-cr-accent hover:underline break-all text-sm" target="_blank" rel="noopener">' + escapeHtml(s.url) + '</a>' : '<span class="text-cr-muted text-sm">—</span>';
        const mobilePort = (s.port != null && s.port !== '') ? '<span class="font-mono text-cr-accent">' + escapeHtml(String(s.port)) + '</span>' : (s.portNote ? '<span class="text-cr-muted">' + escapeHtml(s.portNote) + '</span>' : '<span class="text-cr-muted">—</span>');
        return '<div class="rounded-lg border border-cr-border bg-cr-surface p-4">' +
          '<div class="font-medium text-cr-text mb-2">' + escapeHtml(s.name) + (s.kind === 'proxy' ? ' <span class="text-cr-muted text-xs">(proxy)</span>' : '') + (s.kind === 'php' ? ' <span class="text-cr-muted text-xs">(PHP)</span>' : '') + '</div>' +
          '<div class="space-y-1 text-sm text-cr-muted"><div>Porta ' + mobilePort + '</div>' +
          '<div>' + urlLine + '</div>' +
          (s.pm2 ? '<div>PM2 <span class="font-mono">' + escapeHtml(s.pm2) + '</span></div>' : '') +
          '<div class="pt-2">' + (s.listening === true ? '<span class="text-cr-accent">In ascolto</span>' : s.listening === false ? '<span class="text-cr-danger">Non in ascolto</span>' : '<span class="text-cr-muted">Stato n/d</span>') + '</div>' +
