    <a href="/incidents" class="min-h-[44px] inline-flex items-center justify-center px-3 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover border border-cr-border text-sm font-medium text-cr-text text-center">Incidenti</a>
