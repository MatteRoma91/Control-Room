      <table class="w-full">
        <thead class="bg-slate-700/50">
          <tr>
            <th class="text-left px-4 py-3 text-slate-300 font-medium">Webapp</th>
            <th class="text-left px-4 py-3 text-slate-300 font-medium">URL</th>
            <th class="text-left px-4 py-3 text-slate-300 font-medium">Status</th>
            <th class="text-left px-4 py-3 text-slate-300 font-medium">Tempo (ms)</th>
          </tr>
