<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Control Room</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-900 flex items-center justify-center p-4">
  <main class="w-full max-w-md" role="main">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-slate-100">Control Room</h1>
      <p class="text-slate-400 mt-2">PM2 Dashboard</p>
    </div>
    <div class="bg-slate-800 rounded-xl shadow-xl p-8 border border-slate-700">
      <% if (typeof rateLimited !== 'undefined' && rateLimited) { %>
        <div class="mb-4 p-3 bg-amber-900/50 border border-amber-700 rounded-lg text-amber-200 text-sm" role="alert">
          Troppi tentativi di login. Riprova tra 15 minuti.
        </div>
      <% } else if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-200 text-sm" role="alert">
          Credenziali non valide. Riprova.
        </div>
      <% } %>
      <form method="POST" action="/login" class="space-y-6" aria-labelledby="login-heading">
        <h2 id="login-heading" class="sr-only">Accedi a Control Room</h2>
        <div>
          <label for="username" class="block text-sm font-medium text-slate-300 mb-2">Utente</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            autofocus
            autocomplete="username"
            aria-required="true"
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 placeholder-slate-500 focus:ring-2 focus:ring-emerald-500 focus:border-transparent focus:outline-none"
            placeholder="Username"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-300 mb-2">Password</label>
          <div class="relative" data-password-toggle="3">
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              aria-required="true"
              class="w-full px-4 py-2 pr-12 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 placeholder-slate-500 focus:ring-2 focus:ring-emerald-500 focus:border-transparent focus:outline-none"
              placeholder="Password"
            />
            <button type="button" data-password-toggle-btn class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded text-slate-400 hover:text-slate-300 hover:bg-slate-600 transition-colors" aria-label="Mostra password (tieni premuto 3 secondi)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button>
          </div>
        </div>
        <button
          type="submit"
          class="w-full py-2.5 px-4 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-medium transition focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
          aria-label="Invia credenziali per accedere"
        >
          Accedi
        </button>
      </form>
    </div>
  </main>
  <%- include('partials/password-toggle-script') %>
</body>
</html>
