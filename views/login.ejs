<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Control Room</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-900 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-slate-100">Control Room</h1>
      <p class="text-slate-400 mt-2">PM2 Dashboard</p>
    </div>
    <div class="bg-slate-800 rounded-xl shadow-xl p-8 border border-slate-700">
      <% if (error) { %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-200 text-sm">
          Credenziali non valide. Riprova.
        </div>
      <% } %>
      <form method="POST" action="/login" class="space-y-6">
        <div>
          <label for="username" class="block text-sm font-medium text-slate-300 mb-2">Utente</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            autofocus
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 placeholder-slate-500 focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
            placeholder="Username"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-300 mb-2">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 placeholder-slate-500 focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
            placeholder="Password"
          />
        </div>
        <button
          type="submit"
          class="w-full py-2.5 px-4 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-medium transition"
        >
          Accedi
        </button>
      </form>
    </div>
  </div>
</body>
</html>
