<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0d9488">
  <title>Login - Control Room</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png">
  <%- include('partials/head-common') %>
  <script defer src="/js/cr-theme.js"></script>
</head>
<body class="min-h-screen bg-cr-canvas text-cr-text font-sans antialiased flex flex-col items-center justify-center p-4 relative">
  <div class="absolute top-4 right-4">
    <button
      type="button"
      data-cr-theme-cycle
      class="p-2.5 rounded-lg border border-cr-border bg-cr-surface hover:bg-cr-surface2 text-cr-muted hover:text-cr-text focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-canvas min-h-[44px] min-w-[44px] flex items-center justify-center"
      title="Cambia tema"
      aria-label="Cambia tema"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
    </button>
  </div>
  <main class="w-full max-w-md" role="main">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-cr-text tracking-tight">Control Room</h1>
      <p class="text-cr-muted mt-2 text-sm">PM2 dashboard</p>
    </div>
    <div class="bg-cr-surface rounded-2xl shadow-xl p-8 border border-cr-border">
      <% if (typeof rateLimited !== 'undefined' && rateLimited) { %>
        <div class="mb-4 p-3 bg-[var(--cr-warning-bg)] border border-cr-warning rounded-lg text-cr-warning text-sm" role="alert">
          Troppi tentativi di login. Riprova tra 15 minuti.
        </div>
      <% } else if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 p-3 bg-[var(--cr-danger-bg)] border border-cr-danger rounded-lg text-cr-danger text-sm" role="alert">
          Credenziali non valide. Riprova.
        </div>
      <% } %>
      <form method="POST" action="/login" class="space-y-6" aria-labelledby="login-heading">
        <h2 id="login-heading" class="sr-only">Accedi a Control Room</h2>
        <div>
          <label for="username" class="block text-sm font-medium text-cr-text mb-2">Utente</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            autofocus
            autocomplete="username"
            aria-required="true"
            class="w-full px-4 py-2.5 rounded-lg bg-cr-input border border-cr-inputBorder text-cr-text placeholder-cr-muted focus:outline-none focus:ring-2 focus:ring-cr-accent focus:border-transparent"
            placeholder="Username"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-cr-text mb-2">Password</label>
          <div class="relative" data-password-toggle="3">
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              aria-required="true"
              class="w-full px-4 py-2.5 pr-12 rounded-lg bg-cr-input border border-cr-inputBorder text-cr-text placeholder-cr-muted focus:outline-none focus:ring-2 focus:ring-cr-accent focus:border-transparent"
              placeholder="Password"
            />
            <button type="button" data-password-toggle-btn class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded text-cr-muted hover:text-cr-text hover:bg-cr-navHover transition-colors" aria-label="Mostra password (tieni premuto 3 secondi)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button>
          </div>
        </div>
        <button
          type="submit"
          class="w-full py-2.5 px-4 rounded-lg bg-cr-accent hover:opacity-90 text-white dark:text-slate-900 font-semibold transition focus:outline-none focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-surface"
          aria-label="Invia credenziali per accedere"
        >
          Accedi
        </button>
      </form>
    </div>
  </main>
  <%- include('partials/password-toggle-script') %>
</body>
</html>
