<a href="/settings" class="inline-block mb-4 text-emerald-400 hover:underline focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900 rounded">
  &larr; Impostazioni
</a>

<section class="mb-8" aria-labelledby="2fa-heading">
  <h1 id="2fa-heading" class="text-2xl font-bold text-slate-200 mb-6">Autenticazione a due fattori</h1>

  <% if (settings.totpEnabled) { %>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 max-w-xl">
      <div class="flex items-center gap-2 mb-4">
        <span class="px-2 py-0.5 rounded text-xs font-medium bg-emerald-900/60 text-emerald-300">Attivo</span>
      </div>
      <p class="text-slate-300 mb-4">L'autenticazione a due fattori è attiva. Ogni login richiederà un codice da Google Authenticator.</p>
      <div id="disable2FASection">
        <button
          type="button"
          id="btnDisable2FA"
          class="px-4 py-2 rounded-lg bg-red-700 hover:bg-red-600 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 focus:ring-offset-slate-900"
        >
          Disattiva 2FA
        </button>
        <div id="disable2FAForm" class="hidden mt-4 p-4 bg-slate-700/50 rounded-lg space-y-2">
          <label for="disablePassword" class="block text-sm text-slate-400">Password attuale</label>
          <div class="relative" data-password-toggle="3">
            <input type="password" id="disablePassword" class="w-full px-4 py-2 pr-12 rounded-lg bg-slate-700 border border-slate-600 text-slate-100" placeholder="Conferma password" />
            <button type="button" data-password-toggle-btn class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded text-slate-400 hover:text-slate-300 hover:bg-slate-600 transition-colors" aria-label="Mostra password (tieni premuto 3 secondi)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button>
          </div>
          <div class="flex gap-2">
            <button type="button" id="btnConfirmDisable" class="px-3 py-1.5 rounded bg-red-600 hover:bg-red-500 text-sm">Conferma disattivazione</button>
            <button type="button" id="btnCancelDisable" class="px-3 py-1.5 rounded bg-slate-600 hover:bg-slate-500 text-sm">Annulla</button>
          </div>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 max-w-xl" id="setup2FASection">
      <p class="text-slate-300 mb-4">Configura Google Authenticator (o un'app compatibile) per proteggere l'accesso con un secondo fattore.</p>
      <button
        type="button"
        id="btnStartSetup"
        class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900"
      >
        Configura 2FA
      </button>

      <div id="setup2FAFlow" class="hidden mt-6 space-y-4">
        <div class="p-4 bg-slate-700/50 rounded-lg">
          <h3 class="text-sm font-medium text-slate-200 mb-2">1. Scansiona il QR code con l'app</h3>
          <div id="qrContainer" class="flex justify-center p-4 bg-white rounded-lg inline-block">
            <img id="qrImage" src="" alt="QR code per Google Authenticator" class="w-48 h-48" />
          </div>
        </div>
        <div class="p-4 bg-slate-700/50 rounded-lg">
          <h3 class="text-sm font-medium text-slate-200 mb-2">2. Inserisci il codice di verifica</h3>
          <input
            type="text"
            id="verifyCode"
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono text-center"
            placeholder="000000"
            maxlength="6"
            pattern="[0-9]{6}"
          />
          <button
            type="button"
            id="btnVerifyCode"
            class="mt-2 px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-sm"
          >
            Verifica e attiva
          </button>
        </div>
      </div>
    </div>
  <% } %>
</section>

<script>
  document.getElementById('btnStartSetup')?.addEventListener('click', async function() {
    try {
      const res = await fetch('/api/2fa/setup', { method: 'POST' });
      const data = await res.json();
      if (data.qrDataUrl) {
        document.getElementById('qrImage').src = data.qrDataUrl;
        document.getElementById('setup2FAFlow').classList.remove('hidden');
        document.getElementById('btnStartSetup').classList.add('hidden');
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (data.error || 'Setup fallito'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('btnVerifyCode')?.addEventListener('click', async function() {
    const code = document.getElementById('verifyCode').value.trim();
    if (code.length !== 6) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Inserisci un codice a 6 cifre', type: 'error' } }));
      return;
    }
    try {
      const res = await fetch('/api/2fa/verify-setup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (data.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: '2FA attivato con successo', type: 'success' } }));
        setTimeout(() => location.reload(), 500);
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (data.error || 'Codice non corretto'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('btnDisable2FA')?.addEventListener('click', function() {
    document.getElementById('disable2FAForm').classList.toggle('hidden');
  });

  document.getElementById('btnCancelDisable')?.addEventListener('click', function() {
    document.getElementById('disable2FAForm').classList.add('hidden');
    document.getElementById('disablePassword').value = '';
  });

  document.getElementById('btnConfirmDisable')?.addEventListener('click', async function() {
    const password = document.getElementById('disablePassword').value;
    if (!password) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Inserisci la password', type: 'error' } }));
      return;
    }
    try {
      const res = await fetch('/api/2fa/disable', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password }),
      });
      const data = await res.json();
      if (data.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: '2FA disattivato', type: 'success' } }));
        setTimeout(() => location.reload(), 500);
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (data.error || 'Password non valida'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });
</script>
