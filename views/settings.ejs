<section class="mb-8" aria-labelledby="settings-heading">
  <h1 id="settings-heading" class="text-2xl font-bold text-slate-200 mb-6">Impostazioni</h1>

  <!-- Autenticazione a due fattori -->
  <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 mb-8 max-w-2xl">
    <h2 class="text-lg font-semibold text-slate-200 mb-4">Autenticazione a due fattori</h2>
    <p class="text-slate-300 mb-4">Proteggi l'accesso con Google Authenticator. Ogni login richiederà un codice a 6 cifre generato dall'app.</p>
    <a
      href="/settings/2fa-setup"
      class="inline-block px-4 py-2 rounded-lg bg-slate-600 hover:bg-slate-500 focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900"
    >
      <% if (settings.totpEnabled) { %>
        Gestisci 2FA
      <% } else { %>
        Configura 2FA
      <% } %>
    </a>
    <% if (settings.totpEnabled) { %>
      <span class="ml-3 px-2 py-0.5 rounded text-xs font-medium bg-emerald-900/60 text-emerald-300">Attivo</span>
    <% } else { %>
      <span class="ml-3 px-2 py-0.5 rounded text-xs font-medium bg-slate-600 text-slate-400">Non configurato</span>
    <% } %>
  </div>

  <form id="settingsForm" class="space-y-8 max-w-2xl">
    <!-- Firewall IP Whitelist -->
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-6">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Firewall - IP Whitelist</h2>
      <p class="text-sm text-slate-400 mb-4">Blocca l'accesso alla Control Room da IP non autorizzati. Se abilitato, solo gli IP nella lista possono accedere (anche prima del login).</p>
      <label class="flex items-center gap-2 cursor-pointer mb-4">
        <input type="checkbox" id="ipWhitelistEnabled" name="ipWhitelistEnabled" value="1" <%= settings.ipWhitelistEnabled ? 'checked' : '' %>
          class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
        <span class="text-slate-300">Abilita whitelist IP</span>
      </label>
      <div class="mb-4">
        <label for="ipWhitelist" class="block text-sm text-slate-400 mb-1">IP autorizzati (uno per riga)</label>
        <textarea id="ipWhitelist" name="ipWhitelist" rows="4" placeholder="192.168.1.100&#10;203.0.113.50"
          class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono text-sm"><%= (settings.ipWhitelist || []).join('\n') %></textarea>
        <p class="text-xs text-slate-500 mt-1">Supporta anche CIDR IPv4 (es. <code>10.0.0.0/24</code>).</p>
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <label class="text-sm text-slate-300">
          Durata Panic (min)
          <input type="number" id="panicDurationMin" value="30" min="5" max="240" class="ml-2 w-24 px-2 py-1 rounded bg-slate-700 border border-slate-600 text-slate-100" />
        </label>
        <button type="button" id="btnPanicActivate" class="px-4 py-2 rounded-lg bg-amber-700 hover:bg-amber-600 text-amber-100">
          Attiva Panic Mode
        </button>
        <button type="button" id="btnPanicDisable" class="px-4 py-2 rounded-lg bg-slate-600 hover:bg-slate-500 <%= settings.panicMode ? '' : 'hidden' %>">
          Disattiva Panic
        </button>
        <% if (settings.panicMode) { %>
        <span class="px-2 py-1 rounded text-xs bg-amber-900/60 text-amber-300">Panic attivo: solo <%= settings.panicModeIp || 'questo IP' %></span>
        <% } %>
      </div>
      <p class="text-xs text-slate-500 mt-2">Panic Mode: blocca tutto il traffico tranne il tuo IP attuale. Usa in emergenza.</p>
    </div>

    <!-- Notifiche Webhook -->
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-6">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Notifiche (Discord / Slack / Telegram)</h2>
      <div class="space-y-4">
        <div>
          <label for="webhookType" class="block text-sm text-slate-400 mb-1">Tipo</label>
          <select id="webhookType" name="webhookType" class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100">
            <option value="discord" <%= (settings.webhookType || 'discord') === 'discord' ? 'selected' : '' %>>Discord Webhook</option>
            <option value="slack" <%= settings.webhookType === 'slack' ? 'selected' : '' %>>Slack Webhook</option>
            <option value="telegram" <%= settings.webhookType === 'telegram' ? 'selected' : '' %>>Telegram</option>
          </select>
        </div>
        <div id="discordFields">
          <label for="webhookUrl" class="block text-sm text-slate-400 mb-1">URL Webhook (Discord / Slack)</label>
          <input type="url" id="webhookUrl" name="webhookUrl" placeholder="https://discord.com/api/webhooks/..."
            value="<%= (settings.webhookUrl || '') %>"
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono text-sm" />
        </div>
        <div id="telegramFields" class="hidden space-y-2">
          <div>
            <label for="telegramBotToken" class="block text-sm text-slate-400 mb-1">Bot Token</label>
            <div class="relative" data-password-toggle="3">
              <input type="password" id="telegramBotToken" name="telegramBotToken" placeholder="123456:ABC..."
                value="<%= (settings.telegramBotToken || '') %>"
                class="w-full px-4 py-2 pr-12 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono text-sm" />
              <button type="button" data-password-toggle-btn class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded text-slate-400 hover:text-slate-300 hover:bg-slate-600 transition-colors" aria-label="Mostra password (tieni premuto 3 secondi)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button>
            </div>
          </div>
          <div>
            <label for="telegramChatId" class="block text-sm text-slate-400 mb-1">Chat ID</label>
            <input type="text" id="telegramChatId" name="telegramChatId" placeholder="-1001234567890"
              value="<%= (settings.telegramChatId || '') %>"
              class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono text-sm" />
          </div>
        </div>
        <div class="border-t border-slate-600 pt-4 mt-4">
          <h3 class="text-sm font-medium text-slate-300 mb-3">Tipi di notifica (seleziona quali ricevere)</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnCrash" value="1" <%= settings.notifyOnCrash !== false ? 'checked' : '' %>
                  class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
                <span class="text-slate-300">Crash processo</span>
              </label>
              <span class="text-xs text-slate-500">Quando un processo PM2 termina in modo anomalo (exit).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnRestart" value="1" <%= settings.notifyOnRestart !== false ? 'checked' : '' %>
                  class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
                <span class="text-slate-300">Crash loop</span>
              </label>
              <span class="text-xs text-slate-500">Quando un processo viene riavviato più volte in breve tempo (≥3 restart).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnException" value="1" <%= settings.notifyOnException === true || (settings.notifyOnException !== false && settings.notifyOnCrash !== false) ? 'checked' : '' %>
                  class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
                <span class="text-slate-300">Eccezioni non gestite</span>
              </label>
              <span class="text-xs text-slate-500">Quando un processo lancia un'eccezione non catturata (uncaught exception).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnLogErr" value="1" <%= settings.notifyOnLogErr === true ? 'checked' : '' %>
                  class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
                <span class="text-slate-300">Stderr (log di errore)</span>
              </label>
              <span class="text-xs text-slate-500">Messaggi scritti su stderr dai processi. Può essere molto rumoroso.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Configurazioni SSH -->
    <div class="rounded-lg border border-slate-700 bg-slate-800 p-6" id="sshProfilesSection">
      <h2 class="text-lg font-semibold text-slate-200 mb-2">Configurazioni SSH</h2>
      <p class="text-sm text-slate-400 mb-4">Salva host e username per diverse connessioni. La password va inserita al momento della connessione e non viene mai salvata.</p>
      <div id="sshProfilesList" class="space-y-4 mb-4">
        <% (settings.sshProfiles || []).forEach((p, i) => { %>
        <div class="ssh-profile-card p-4 bg-slate-700/50 rounded-lg border border-slate-600" data-id="<%= p.id || ('p' + i) %>">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-2 text-sm">
            <input type="text" data-field="name" placeholder="Nome" value="<%= (p.name || '') %>"
              class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
            <input type="text" data-field="host" placeholder="Host/IP" value="<%= (p.host || '') %>"
              class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100 font-mono" />
            <input type="number" data-field="port" placeholder="22" value="<%= (p.port || 22) %>"
              class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
            <input type="text" data-field="username" placeholder="Utente" value="<%= (p.username || '') %>"
              class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
            <select data-field="authType" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100">
              <option value="key" <%= p.authType === 'password' ? '' : 'selected' %>>Chiave</option>
              <option value="password" <%= p.authType === 'password' ? 'selected' : '' %>>Password</option>
            </select>
          </div>
          <div class="mt-2 ssh-key-path-row" style="<%= p.authType === 'password' ? 'display:none' : '' %>">
            <input type="text" data-field="keyPath" placeholder="Path chiave (default: ~/.ssh/id_rsa)" value="<%= (p.keyPath || '') %>"
              class="w-full mt-1 px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100 font-mono text-xs" />
          </div>
          <button type="button" class="ssh-remove mt-2 text-red-400 hover:text-red-300 text-xs">Rimuovi</button>
        </div>
        <% }); %>
      </div>
      <button type="button" id="btnAddSshProfile" class="px-3 py-1.5 rounded-lg bg-slate-600 hover:bg-slate-500 text-sm">
        + Aggiungi connessione
      </button>
    </div>

    <button type="submit" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-medium focus:ring-2 focus:ring-emerald-500">
      Salva impostazioni
    </button>
  </form>
</section>

<script>
  document.getElementById('webhookType').addEventListener('change', function() {
    const isWebhook = this.value === 'discord' || this.value === 'slack';
    document.getElementById('discordFields').classList.toggle('hidden', !isWebhook);
    document.getElementById('telegramFields').classList.toggle('hidden', this.value !== 'telegram');
  });
  document.getElementById('webhookType').dispatchEvent(new Event('change'));

  function collectSshProfiles() {
    const cards = document.querySelectorAll('.ssh-profile-card');
    return Array.from(cards).map(card => {
      const id = card.dataset.id || 'p' + Date.now();
      return {
        id,
        name: card.querySelector('[data-field="name"]')?.value?.trim() || '',
        host: card.querySelector('[data-field="host"]')?.value?.trim() || '',
        port: parseInt(card.querySelector('[data-field="port"]')?.value || '22', 10),
        username: card.querySelector('[data-field="username"]')?.value?.trim() || '',
        authType: card.querySelector('[data-field="authType"]')?.value || 'key',
        keyPath: card.querySelector('[data-field="keyPath"]')?.value?.trim() || ''
      };
    }).filter(p => p.name || p.host || p.username);
  }

  document.getElementById('btnAddSshProfile').addEventListener('click', function() {
    const list = document.getElementById('sshProfilesList');
    const card = document.createElement('div');
    card.className = 'ssh-profile-card p-4 bg-slate-700/50 rounded-lg border border-slate-600';
    card.dataset.id = 'p' + Date.now();
    card.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-2 text-sm">
        <input type="text" data-field="name" placeholder="Nome" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
        <input type="text" data-field="host" placeholder="Host/IP" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100 font-mono" />
        <input type="number" data-field="port" placeholder="22" value="22" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
        <input type="text" data-field="username" placeholder="Utente" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100" />
        <select data-field="authType" class="px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100">
          <option value="key" selected>Chiave</option>
          <option value="password">Password</option>
        </select>
      </div>
      <div class="mt-2 ssh-key-path-row">
        <input type="text" data-field="keyPath" placeholder="Path chiave (default: ~/.ssh/id_rsa)" class="w-full mt-1 px-2 py-1.5 rounded bg-slate-700 border border-slate-600 text-slate-100 font-mono text-xs" />
      </div>
      <button type="button" class="ssh-remove mt-2 text-red-400 hover:text-red-300 text-xs">Rimuovi</button>
    `;
    card.querySelector('[data-field="authType"]').addEventListener('change', function() {
      card.querySelector('.ssh-key-path-row').style.display = this.value === 'password' ? 'none' : '';
    });
    card.querySelector('.ssh-remove').addEventListener('click', () => card.remove());
    list.appendChild(card);
  });

  document.querySelectorAll('.ssh-profile-card').forEach(card => {
    card.querySelector('[data-field="authType"]')?.addEventListener('change', function() {
      card.querySelector('.ssh-key-path-row').style.display = this.value === 'password' ? 'none' : '';
    });
    card.querySelector('.ssh-remove')?.addEventListener('click', () => card.remove());
  });

  document.getElementById('btnPanicActivate').addEventListener('click', async function() {
    const confirm = await requestStrongConfirm({
      title: 'Conferma attivazione Panic Mode',
      message: 'Solo il tuo IP attuale potrà accedere fino alla scadenza.',
      expectedPhrase: 'PANIC-ACTIVATE',
    });
    if (!confirm || !confirm.ok) return;
    try {
      const durationMin = parseInt(document.getElementById('panicDurationMin')?.value || '30', 10);
      const res = await fetch('/api/settings/panic-activate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ durationMin, confirmPhrase: confirm.confirmPhrase }),
      });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Panic Mode attivo', type: 'success' } }));
        location.reload();
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Operazione fallita'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('btnPanicDisable').addEventListener('click', async function() {
    try {
      const confirm = await requestStrongConfirm({
        title: 'Conferma disattivazione Panic Mode',
        message: 'L accesso tornerà alle regole whitelist standard.',
        expectedPhrase: 'PANIC-DISABLE',
      });
      if (!confirm || !confirm.ok) return;
      const res = await fetch('/api/settings/panic-disable', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirmPhrase: confirm.confirmPhrase }),
      });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Panic Mode disattivato', type: 'success' } }));
        location.reload();
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Operazione fallita'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('settingsForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const ipList = (form.ipWhitelist?.value || '').split('\n').map(s => s.trim()).filter(Boolean);
    const data = {
      ipWhitelistEnabled: form.ipWhitelistEnabled?.checked === true,
      ipWhitelist: ipList,
      webhookType: form.webhookType?.value || 'discord',
      webhookUrl: form.webhookUrl?.value || '',
      telegramBotToken: form.telegramBotToken?.value || '',
      telegramChatId: form.telegramChatId?.value || '',
      notifyOnCrash: form.notifyOnCrash?.checked === true,
      notifyOnRestart: form.notifyOnRestart?.checked === true,
      notifyOnException: form.notifyOnException?.checked === true,
      notifyOnLogErr: form.notifyOnLogErr?.checked === true,
      sshProfiles: collectSshProfiles()
    };
    try {
      const res = await fetch('/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Impostazioni salvate', type: 'success' } }));
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Salvataggio fallito'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });
</script>
