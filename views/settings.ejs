<section class="mb-8" aria-labelledby="settings-heading">
  <h1 id="settings-heading" class="text-2xl font-bold text-cr-text mb-6">Impostazioni</h1>

  <div class="rounded-lg border border-cr-border bg-cr-surface p-6 mb-8 max-w-2xl">
    <h2 class="text-lg font-semibold text-cr-text mb-2">Session Store Redis</h2>
    <p id="redisHealthText" class="text-sm text-cr-text mb-3">Verifica stato Redis...</p>
    <button type="button" id="btnCheckRedisHealth" class="px-3 py-1.5 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm">Controlla stato Redis</button>
  </div>

  <div class="rounded-lg border border-cr-border bg-cr-surface p-6 mb-8 max-w-2xl">
    <h2 class="text-lg font-semibold text-cr-text mb-2">Health Notifiche</h2>
    <p id="notifyHealthText" class="text-sm text-cr-text mb-3">Verifica stato notifiche...</p>
    <button type="button" id="btnCheckNotifyHealth" class="px-3 py-1.5 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm">Controlla stato notifiche</button>
  </div>

  <!-- Autenticazione a due fattori -->
  <div class="rounded-lg border border-cr-border bg-cr-surface p-6 mb-8 max-w-2xl">
    <h2 class="text-lg font-semibold text-cr-text mb-4">Autenticazione a due fattori</h2>
    <p class="text-cr-text mb-4">Proteggi l'accesso con Google Authenticator. Ogni login richiederà un codice a 6 cifre generato dall'app.</p>
    <a
      href="/settings/2fa-setup"
      class="inline-block px-4 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-canvas"
    >
      <% if (settings.totpEnabled) { %>
        Gestisci 2FA
      <% } else { %>
        Configura 2FA
      <% } %>
    </a>
    <% if (settings.totpEnabled) { %>
      <span class="ml-3 px-2 py-0.5 rounded text-xs font-medium bg-[var(--cr-success-bg)] text-cr-accent">Attivo</span>
    <% } else { %>
      <span class="ml-3 px-2 py-0.5 rounded text-xs font-medium bg-cr-surface2 text-cr-muted">Non configurato</span>
    <% } %>
  </div>

  <form id="settingsForm" class="space-y-8 max-w-2xl">
    <!-- Firewall IP Whitelist -->
    <div class="rounded-lg border border-cr-border bg-cr-surface p-6">
      <h2 class="text-lg font-semibold text-cr-text mb-4">Firewall - IP Whitelist</h2>
      <p class="text-sm text-cr-muted mb-4">Blocca l'accesso alla Control Room da IP non autorizzati. Se abilitato, solo gli IP nella lista possono accedere (anche prima del login).</p>
      <label class="flex items-center gap-2 cursor-pointer mb-4">
        <input type="checkbox" id="ipWhitelistEnabled" name="ipWhitelistEnabled" value="1" <%= settings.ipWhitelistEnabled ? 'checked' : '' %>
          class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
        <span class="text-cr-text">Abilita whitelist IP</span>
      </label>
      <div class="mb-4">
        <label for="ipWhitelist" class="block text-sm text-cr-muted mb-1">IP autorizzati (uno per riga)</label>
        <textarea id="ipWhitelist" name="ipWhitelist" rows="4" placeholder="192.168.1.100&#10;203.0.113.50"
          class="w-full px-4 py-2 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-sm"><%= (settings.ipWhitelist || []).join('\n') %></textarea>
        <p class="text-xs text-cr-muted mt-1">Supporta anche CIDR IPv4 (es. <code>10.0.0.0/24</code>).</p>
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <label class="text-sm text-cr-text">
          Durata Panic (min)
          <input type="number" id="panicDurationMin" value="30" min="5" max="240" class="ml-2 w-24 px-2 py-1 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
        </label>
        <button type="button" id="btnPanicActivate" class="px-4 py-2 rounded-lg bg-cr-warning hover:opacity-90 text-white dark:text-slate-900 font-medium">
          Attiva Panic Mode
        </button>
        <button type="button" id="btnPanicDisable" class="px-4 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover <%= settings.panicMode ? '' : 'hidden' %>">
          Disattiva Panic
        </button>
        <% if (settings.panicMode) { %>
        <span class="px-2 py-1 rounded text-xs bg-[var(--cr-warning-bg)] text-cr-warning">Panic attivo: solo <%= settings.panicModeIp || 'questo IP' %></span>
        <% } %>
      </div>
      <p class="text-xs text-cr-muted mt-2">Panic Mode: blocca tutto il traffico tranne il tuo IP attuale. Usa in emergenza.</p>
    </div>

    <!-- Notifiche Webhook -->
    <div class="rounded-lg border border-cr-border bg-cr-surface p-6">
      <h2 class="text-lg font-semibold text-cr-text mb-4">Notifiche (Discord / Slack / Telegram)</h2>
      <div class="space-y-4">
        <div>
          <label for="webhookType" class="block text-sm text-cr-muted mb-1">Tipo</label>
          <select id="webhookType" name="webhookType" class="w-full px-4 py-2 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text">
            <option value="discord" <%= (settings.webhookType || 'discord') === 'discord' ? 'selected' : '' %>>Discord Webhook</option>
            <option value="slack" <%= settings.webhookType === 'slack' ? 'selected' : '' %>>Slack Webhook</option>
            <option value="telegram" <%= settings.webhookType === 'telegram' ? 'selected' : '' %>>Telegram</option>
          </select>
        </div>
        <div id="discordFields">
          <label for="webhookUrl" class="block text-sm text-cr-muted mb-1">URL Webhook (Discord / Slack)</label>
          <input type="url" id="webhookUrl" name="webhookUrl" placeholder="https://discord.com/api/webhooks/..."
            value="<%= (settings.webhookUrl || '') %>"
            class="w-full px-4 py-2 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-sm" />
          <div class="grid grid-cols-1 md:grid-cols-3 gap-2 mt-2">
            <input type="url" id="discordWebhookOps" name="discordWebhookOps" placeholder="Webhook Ops"
              value="<%= (settings.discordWebhookOps || '') %>"
              class="px-3 py-2 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-xs" />
            <input type="url" id="discordWebhookIncidents" name="discordWebhookIncidents" placeholder="Webhook Incidenti"
              value="<%= (settings.discordWebhookIncidents || '') %>"
              class="px-3 py-2 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-xs" />
            <input type="url" id="discordWebhookSecurity" name="discordWebhookSecurity" placeholder="Webhook Security"
              value="<%= (settings.discordWebhookSecurity || '') %>"
              class="px-3 py-2 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-xs" />
          </div>
        </div>
        <div id="telegramFields" class="hidden space-y-2">
          <div>
            <label for="telegramBotToken" class="block text-sm text-cr-muted mb-1">Bot Token</label>
            <div class="relative" data-password-toggle="3">
              <input type="password" id="telegramBotToken" name="telegramBotToken" placeholder="123456:ABC..."
                value="<%= (settings.telegramBotToken || '') %>"
                class="w-full px-4 py-2 pr-12 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-sm" />
              <button type="button" data-password-toggle-btn class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 rounded text-cr-muted hover:text-cr-text hover:bg-cr-navHover transition-colors" aria-label="Mostra password (tieni premuto 3 secondi)"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></button>
            </div>
          </div>
          <div>
            <label for="telegramChatId" class="block text-sm text-cr-muted mb-1">Chat ID</label>
            <input type="text" id="telegramChatId" name="telegramChatId" placeholder="-1001234567890"
              value="<%= (settings.telegramChatId || '') %>"
              class="w-full px-4 py-2 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-sm" />
          </div>
        </div>
        <div class="border-t border-cr-inputBorder pt-4 mt-4">
          <h3 class="text-sm font-medium text-cr-text mb-3">Tipi di notifica (seleziona quali ricevere)</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnCrash" value="1" <%= settings.notifyOnCrash !== false ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Crash processo</span>
              </label>
              <span class="text-xs text-cr-muted">Quando un processo PM2 termina in modo anomalo (exit).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnRestart" value="1" <%= settings.notifyOnRestart !== false ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Crash loop</span>
              </label>
              <span class="text-xs text-cr-muted">Quando un processo viene riavviato più volte in breve tempo (≥3 restart).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnException" value="1" <%= settings.notifyOnException === true || (settings.notifyOnException !== false && settings.notifyOnCrash !== false) ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Eccezioni non gestite</span>
              </label>
              <span class="text-xs text-cr-muted">Quando un processo lancia un'eccezione non catturata (uncaught exception).</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnLogErr" value="1" <%= settings.notifyOnLogErr === true ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Stderr (log di errore)</span>
              </label>
              <span class="text-xs text-cr-muted">Messaggi scritti su stderr dai processi. Può essere molto rumoroso.</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnRunbook" value="1" <%= settings.notifyOnRunbook === true ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Runbook (manuali/batch)</span>
              </label>
              <span class="text-xs text-cr-muted">Notifica completamento runbook e runbook batch.</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnIncident" value="1" <%= settings.notifyOnIncident !== false ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Incidenti</span>
              </label>
              <span class="text-xs text-cr-muted">Creazione/aggiornamento stato incidenti.</span>
            </li>
            <li class="flex items-start gap-3">
              <label class="flex items-center gap-2 cursor-pointer shrink-0 mt-0.5">
                <input type="checkbox" name="notifyOnSecurity" value="1" <%= settings.notifyOnSecurity === true ? 'checked' : '' %>
                  class="rounded border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
                <span class="text-cr-text">Security admin</span>
              </label>
              <span class="text-xs text-cr-muted">Revoca sessioni e azioni security sensibili.</span>
            </li>
          </ul>
        </div>
        <% 
          var pm2Rows = (typeof pm2Processes !== 'undefined' && Array.isArray(pm2Processes)) ? pm2Processes : [];
          var perMap = settings.notifyPm2PerApp || {};
          var savedOnlyApps = settings.notifyPm2OnlyApps || [];
          var matrixNameSet = {};
          pm2Rows.forEach(function(p) { if (p && p.name) matrixNameSet[p.name] = true; });
          Object.keys(perMap).forEach(function(n) { matrixNameSet[n] = true; });
          savedOnlyApps.forEach(function(n) { matrixNameSet[n] = true; });
          var matrixNames = Object.keys(matrixNameSet).sort(function(a, b) { return a.localeCompare(b); });
          var scopeOnlyListed = settings.notifyPm2Scope === 'onlyListed';
        %>
        <div class="border-t border-cr-inputBorder pt-4 mt-4" id="notifyPm2Advanced" aria-labelledby="notify-pm2-adv-heading">
          <h3 id="notify-pm2-adv-heading" class="text-sm font-medium text-cr-text mb-2">Filtri notifiche PM2 per processo</h3>
          <p class="text-xs text-cr-muted mb-3">
            Valutazione in ordine: (1) master globali sopra (Crash, Loop, ecc.); (2) se scegli «Solo app selezionate», solo quelle possono generare notifiche PM2; (3) nella tabella, deseleziona una casella per escludere quel tipo per quel processo.
            Con «Solo app selezionate» e lista vuota non partono notifiche PM2 né runbook «recover» per singola app. Massimo 64 nomi processo. Con elenco non vuoto, solo le app spuntate ricevono notifiche PM2 e runbook recover per app.
          </p>
          <fieldset class="space-y-2 mb-4">
            <legend class="text-xs font-medium text-cr-text mb-2">Ambito processi PM2</legend>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="notifyPm2Scope" value="all" <%= !scopeOnlyListed ? 'checked' : '' %>
                class="rounded-full border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
              <span class="text-sm text-cr-text">Tutte le app PM2</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="notifyPm2Scope" value="onlyListed" <%= scopeOnlyListed ? 'checked' : '' %>
                class="rounded-full border-cr-inputBorder bg-cr-surface2 text-cr-accent focus:ring-cr-accent" />
              <span class="text-sm text-cr-text">Solo app selezionate (notifiche PM2 + runbook per app)</span>
            </label>
          </fieldset>
          <div id="notifyPm2OnlyAppsPanel" class="mb-4 rounded-lg border border-cr-border bg-cr-surface2/50 p-3 <%= scopeOnlyListed ? '' : 'hidden' %>">
            <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
              <span class="text-xs font-medium text-cr-text">Seleziona le app che possono inviare notifiche PM2</span>
              <span class="flex gap-2">
                <button type="button" id="btnNotifyPm2OnlyAll" class="px-2 py-1 rounded text-xs bg-cr-surface2 hover:bg-cr-navHover border border-cr-border">Tutte</button>
                <button type="button" id="btnNotifyPm2OnlyNone" class="px-2 py-1 rounded text-xs bg-cr-surface2 hover:bg-cr-navHover border border-cr-border">Nessuna</button>
              </span>
            </div>
            <div id="notifyPm2OnlyAppsList" class="flex flex-wrap gap-2 max-h-40 overflow-y-auto">
              <% matrixNames.forEach(function(appName) { %>
              <label class="inline-flex items-center gap-1.5 px-2 py-1 rounded border border-cr-border bg-cr-surface text-xs cursor-pointer">
                <input type="checkbox" class="notify-pm2-only-cb rounded border-cr-inputBorder" data-app-name="<%= appName.replace(/"/g, '&quot;') %>"
                  <%= savedOnlyApps.indexOf(appName) >= 0 ? 'checked' : '' %> />
                <span class="font-mono text-cr-text"><%= appName %></span>
              </label>
              <% }); %>
            </div>
            <p class="text-[11px] text-cr-muted mt-2">Aggiorna l’elenco dopo aver aggiunto processi in PM2 (pulsante sotto).</p>
          </div>
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <button type="button" id="btnRefreshPm2NotifyList" class="px-3 py-1.5 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm">Aggiorna elenco da PM2</button>
          </div>
          <div class="overflow-x-auto rounded-lg border border-cr-border">
            <table class="w-full text-sm min-w-[520px]">
              <thead>
                <tr class="border-b border-cr-border bg-cr-surface2/80 text-left">
                  <th class="px-3 py-2 font-medium text-cr-text">Processo</th>
                  <th class="px-2 py-2 font-medium text-cr-muted text-center w-24">Crash</th>
                  <th class="px-2 py-2 font-medium text-cr-muted text-center w-24">Loop</th>
                  <th class="px-2 py-2 font-medium text-cr-muted text-center w-24">Eccez.</th>
                  <th class="px-2 py-2 font-medium text-cr-muted text-center w-24">Stderr</th>
                  <th class="px-2 py-2 w-20"></th>
                </tr>
              </thead>
              <tbody id="notifyPm2MatrixBody">
                <% matrixNames.forEach(function(appName) {
                     var row = perMap[appName] || {};
                %>
                <tr class="border-b border-cr-border/80 hover:bg-cr-navHover/30" data-app-name="<%= appName.replace(/"/g, '&quot;') %>">
                  <td class="px-3 py-2 font-mono text-cr-text"><%= appName %></td>
                  <td class="px-2 py-2 text-center">
                    <input type="checkbox" data-nt="crash" class="rounded border-cr-inputBorder" <%= row.crash === false ? '' : 'checked' %>
                      aria-label="Notifica crash per <%= appName.replace(/"/g, '&quot;') %>" />
                  </td>
                  <td class="px-2 py-2 text-center">
                    <input type="checkbox" data-nt="restartLoop" class="rounded border-cr-inputBorder" <%= row.restartLoop === false ? '' : 'checked' %>
                      aria-label="Notifica crash loop per <%= appName.replace(/"/g, '&quot;') %>" />
                  </td>
                  <td class="px-2 py-2 text-center">
                    <input type="checkbox" data-nt="exception" class="rounded border-cr-inputBorder" <%= row.exception === false ? '' : 'checked' %>
                      aria-label="Notifica eccezioni per <%= appName.replace(/"/g, '&quot;') %>" />
                  </td>
                  <td class="px-2 py-2 text-center">
                    <input type="checkbox" data-nt="stderr" class="rounded border-cr-inputBorder" <%= row.stderr === false ? '' : 'checked' %>
                      aria-label="Notifica stderr per <%= appName.replace(/"/g, '&quot;') %>" />
                  </td>
                  <td class="px-2 py-2 text-center">
                    <button type="button" class="notify-pm2-remove-row text-xs text-cr-danger hover:underline">Rimuovi</button>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="flex flex-wrap items-end gap-2 mt-3">
            <div class="flex-1 min-w-[12rem]">
              <label for="notifyPm2AddName" class="block text-xs text-cr-muted mb-1">Aggiungi processo (nome PM2)</label>
              <input type="text" id="notifyPm2AddName" placeholder="es. mia-app"
                class="w-full px-3 py-2 rounded-lg bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-sm" />
            </div>
            <button type="button" id="btnNotifyPm2AddRow" class="px-3 py-2 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm">Aggiungi riga</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Configurazioni SSH -->
    <div class="rounded-lg border border-cr-border bg-cr-surface p-6" id="sshProfilesSection">
      <h2 class="text-lg font-semibold text-cr-text mb-2">Configurazioni SSH</h2>
      <p class="text-sm text-cr-muted mb-4">Salva host e username per diverse connessioni. La password va inserita al momento della connessione e non viene mai salvata.</p>
      <div id="sshProfilesList" class="space-y-4 mb-4">
        <% (settings.sshProfiles || []).forEach((p, i) => { %>
        <div class="ssh-profile-card p-4 bg-cr-surface2 rounded-lg border border-cr-inputBorder" data-id="<%= p.id || ('p' + i) %>">
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-2 text-sm">
            <input type="text" data-field="name" placeholder="Nome" value="<%= (p.name || '') %>"
              class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
            <input type="text" data-field="host" placeholder="Host/IP" value="<%= (p.host || '') %>"
              class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono" />
            <input type="number" data-field="port" placeholder="22" value="<%= (p.port || 22) %>"
              class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
            <input type="text" data-field="username" placeholder="Utente" value="<%= (p.username || '') %>"
              class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
            <select data-field="authType" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text">
              <option value="key" <%= p.authType === 'password' ? '' : 'selected' %>>Chiave</option>
              <option value="password" <%= p.authType === 'password' ? 'selected' : '' %>>Password</option>
            </select>
          </div>
          <div class="mt-2 ssh-key-path-row" style="<%= p.authType === 'password' ? 'display:none' : '' %>">
            <input type="text" data-field="keyPath" placeholder="Path chiave (default: ~/.ssh/id_rsa)" value="<%= (p.keyPath || '') %>"
              class="w-full mt-1 px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-xs" />
          </div>
          <button type="button" class="ssh-remove mt-2 text-cr-danger hover:text-cr-danger text-xs">Rimuovi</button>
        </div>
        <% }); %>
      </div>
      <button type="button" id="btnAddSshProfile" class="px-3 py-1.5 rounded-lg bg-cr-surface2 hover:bg-cr-navHover text-sm">
        + Aggiungi connessione
      </button>
    </div>

    <button type="submit" id="btnSettingsSave" class="px-4 py-2 rounded-lg bg-cr-accent hover:bg-cr-accentHover text-white font-medium focus:ring-2 focus:ring-cr-accent focus:ring-offset-2 focus:ring-offset-cr-canvas min-h-[44px]">
      Salva impostazioni
    </button>
  </form>
</section>

<script>
  async function loadRedisHealth(btn) {
    const el = document.getElementById('redisHealthText');
    if (!el) return;
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(btn, true, 'Verifica…');
    el.textContent = 'Verifica in corso...';
    try {
      const res = await fetch('/api/redis-health');
      const json = await res.json();
      if (json.ok) {
        el.textContent = `Stato: READY | prefix=${json.prefix} | lastOk=${json.lastOkAt || '-'}`;
      } else {
        el.textContent = `Stato: ERRORE | ${json.error || 'n/d'}`;
      }
    } catch (err) {
      el.textContent = 'Errore verifica Redis: ' + err.message;
    }
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(btn, false);
  }
  document.getElementById('btnCheckRedisHealth')?.addEventListener('click', function () { loadRedisHealth(this); });
  loadRedisHealth(null);

  async function loadNotifyHealth(btn) {
    const el = document.getElementById('notifyHealthText');
    if (!el) return;
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(btn, true, 'Verifica…');
    el.textContent = 'Verifica in corso...';
    try {
      const res = await fetch('/api/notifications/health');
      const json = await res.json();
      if (json.ok) {
        el.textContent = `Dead-letter=${json.deadLetterCount} | runbook_recent=${json.recentRunbookEvents} | dedup_cache=${json.dedupCacheSize}`;
      } else {
        el.textContent = `Errore notifiche: ${json.error || 'n/d'}`;
      }
    } catch (err) {
      el.textContent = 'Errore verifica notifiche: ' + err.message;
    }
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(btn, false);
  }
  document.getElementById('btnCheckNotifyHealth')?.addEventListener('click', function () { loadNotifyHealth(this); });
  loadNotifyHealth(null);

  document.getElementById('webhookType').addEventListener('change', function() {
    const isWebhook = this.value === 'discord' || this.value === 'slack';
    document.getElementById('discordFields').classList.toggle('hidden', !isWebhook);
    document.getElementById('telegramFields').classList.toggle('hidden', this.value !== 'telegram');
  });
  document.getElementById('webhookType').dispatchEvent(new Event('change'));

  function syncNotifyPm2ScopePanel() {
    const only = document.querySelector('input[name="notifyPm2Scope"]:checked')?.value === 'onlyListed';
    const panel = document.getElementById('notifyPm2OnlyAppsPanel');
    if (panel) panel.classList.toggle('hidden', !only);
  }
  document.querySelectorAll('input[name="notifyPm2Scope"]').forEach(function (r) {
    r.addEventListener('change', syncNotifyPm2ScopePanel);
  });
  syncNotifyPm2ScopePanel();

  function matrixHasApp(name) {
    return Array.from(document.querySelectorAll('#notifyPm2MatrixBody tr[data-app-name]')).some(function (tr) {
      return tr.getAttribute('data-app-name') === name;
    });
  }

  function appendOnlyAppCheckbox(appName, checked) {
    const list = document.getElementById('notifyPm2OnlyAppsList');
    if (!list) return;
    if (Array.from(list.querySelectorAll('.notify-pm2-only-cb')).some(function (cb) {
      return cb.getAttribute('data-app-name') === appName;
    })) return;
    const label = document.createElement('label');
    label.className = 'inline-flex items-center gap-1.5 px-2 py-1 rounded border border-cr-border bg-cr-surface text-xs cursor-pointer';
    const inp = document.createElement('input');
    inp.type = 'checkbox';
    inp.className = 'notify-pm2-only-cb rounded border-cr-inputBorder';
    inp.setAttribute('data-app-name', appName);
    inp.checked = !!checked;
    const span = document.createElement('span');
    span.className = 'font-mono text-cr-text';
    span.textContent = appName;
    label.appendChild(inp);
    label.appendChild(span);
    list.appendChild(label);
  }

  function appendPm2MatrixRow(appName, row) {
    if (matrixHasApp(appName)) return;
    const tbody = document.getElementById('notifyPm2MatrixBody');
    if (!tbody) return;
    const tr = document.createElement('tr');
    tr.className = 'border-b border-cr-border/80 hover:bg-cr-navHover/30';
    tr.setAttribute('data-app-name', appName);
    const nameTd = document.createElement('td');
    nameTd.className = 'px-3 py-2 font-mono text-cr-text';
    nameTd.textContent = appName;
    tr.appendChild(nameTd);
    var kinds = [
      { k: 'crash', lab: 'crash' },
      { k: 'restartLoop', lab: 'crash loop' },
      { k: 'exception', lab: 'eccezioni' },
      { k: 'stderr', lab: 'stderr' },
    ];
    kinds.forEach(function (item) {
      var td = document.createElement('td');
      td.className = 'px-2 py-2 text-center';
      var inp = document.createElement('input');
      inp.type = 'checkbox';
      inp.className = 'rounded border-cr-inputBorder';
      inp.setAttribute('data-nt', item.k);
      var off = row && row[item.k] === false;
      inp.checked = !off;
      inp.setAttribute('aria-label', 'Notifica ' + item.lab + ' per ' + appName);
      td.appendChild(inp);
      tr.appendChild(td);
    });
    var tdRm = document.createElement('td');
    tdRm.className = 'px-2 py-2 text-center';
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'notify-pm2-remove-row text-xs text-cr-danger hover:underline';
    btn.textContent = 'Rimuovi';
    tdRm.appendChild(btn);
    tr.appendChild(tdRm);
    tbody.appendChild(tr);
    appendOnlyAppCheckbox(appName, false);
  }

  function removePm2NotifyRow(tr) {
    if (!tr) return;
    var name = tr.getAttribute('data-app-name');
    tr.remove();
    if (!name) return;
    document.querySelectorAll('.notify-pm2-only-cb').forEach(function (cb) {
      if (cb.getAttribute('data-app-name') === name) {
        var lb = cb.closest('label');
        if (lb) lb.remove();
      }
    });
  }

  document.getElementById('notifyPm2MatrixBody')?.addEventListener('click', function (e) {
    if (e.target.classList.contains('notify-pm2-remove-row')) {
      removePm2NotifyRow(e.target.closest('tr'));
    }
  });

  document.getElementById('btnNotifyPm2OnlyAll')?.addEventListener('click', function () {
    document.querySelectorAll('.notify-pm2-only-cb').forEach(function (cb) { cb.checked = true; });
  });
  document.getElementById('btnNotifyPm2OnlyNone')?.addEventListener('click', function () {
    document.querySelectorAll('.notify-pm2-only-cb').forEach(function (cb) { cb.checked = false; });
  });

  document.getElementById('btnRefreshPm2NotifyList')?.addEventListener('click', async function () {
    var self = this;
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(self, true, 'Aggiornamento…');
    try {
      var res = await fetch('/api/processes');
      var json = await res.json();
      var list = json.processes || [];
      var added = 0;
      list.forEach(function (p) {
        var n = (p && p.name) ? String(p.name).trim() : '';
        if (!n) return;
        if (!matrixHasApp(n)) {
          appendPm2MatrixRow(n, {});
          added += 1;
        }
      });
      window.dispatchEvent(new CustomEvent('toast', {
        detail: { message: added ? ('Aggiornato: ' + added + ' processo/i aggiunti alla tabella') : 'Elenco già allineato a PM2', type: 'success' },
      }));
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore refresh PM2: ' + err.message, type: 'error' } }));
    }
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(self, false);
  });

  document.getElementById('btnNotifyPm2AddRow')?.addEventListener('click', function () {
    var inp = document.getElementById('notifyPm2AddName');
    var raw = (inp && inp.value) ? inp.value.trim() : '';
    if (!raw) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Inserisci un nome processo', type: 'error' } }));
      return;
    }
    if (raw.length > 200) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Nome troppo lungo (max 200)', type: 'error' } }));
      return;
    }
    if (matrixHasApp(raw)) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Processo già presente in tabella', type: 'error' } }));
      return;
    }
    appendPm2MatrixRow(raw, {});
    inp.value = '';
    window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Riga aggiunta (salva per persistere)', type: 'success' } }));
  });

  function collectNotifyPm2Payload() {
    var scope = document.querySelector('input[name="notifyPm2Scope"]:checked')?.value === 'onlyListed' ? 'onlyListed' : 'all';
    var onlyApps = [];
    document.querySelectorAll('.notify-pm2-only-cb:checked').forEach(function (cb) {
      var n = cb.getAttribute('data-app-name');
      if (n) onlyApps.push(n);
    });
    var perApp = {};
    document.querySelectorAll('#notifyPm2MatrixBody tr[data-app-name]').forEach(function (tr) {
      var app = tr.getAttribute('data-app-name');
      if (!app) return;
      var row = {};
      ['crash', 'restartLoop', 'exception', 'stderr'].forEach(function (k) {
        var inp = tr.querySelector('input[data-nt="' + k + '"]');
        if (inp && !inp.checked) row[k] = false;
      });
      if (Object.keys(row).length) perApp[app] = row;
    });
    return {
      notifyPm2Scope: scope,
      notifyPm2OnlyApps: scope === 'onlyListed' ? onlyApps : [],
      notifyPm2PerApp: perApp,
    };
  }

  function collectSshProfiles() {
    const cards = document.querySelectorAll('.ssh-profile-card');
    return Array.from(cards).map(card => {
      const id = card.dataset.id || 'p' + Date.now();
      return {
        id,
        name: card.querySelector('[data-field="name"]')?.value?.trim() || '',
        host: card.querySelector('[data-field="host"]')?.value?.trim() || '',
        port: parseInt(card.querySelector('[data-field="port"]')?.value || '22', 10),
        username: card.querySelector('[data-field="username"]')?.value?.trim() || '',
        authType: card.querySelector('[data-field="authType"]')?.value || 'key',
        keyPath: card.querySelector('[data-field="keyPath"]')?.value?.trim() || ''
      };
    }).filter(p => p.name || p.host || p.username);
  }

  document.getElementById('btnAddSshProfile').addEventListener('click', function() {
    const list = document.getElementById('sshProfilesList');
    const card = document.createElement('div');
    card.className = 'ssh-profile-card p-4 bg-cr-surface2 rounded-lg border border-cr-inputBorder';
    card.dataset.id = 'p' + Date.now();
    card.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-2 text-sm">
        <input type="text" data-field="name" placeholder="Nome" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
        <input type="text" data-field="host" placeholder="Host/IP" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono" />
        <input type="number" data-field="port" placeholder="22" value="22" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
        <input type="text" data-field="username" placeholder="Utente" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text" />
        <select data-field="authType" class="px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text">
          <option value="key" selected>Chiave</option>
          <option value="password">Password</option>
        </select>
      </div>
      <div class="mt-2 ssh-key-path-row">
        <input type="text" data-field="keyPath" placeholder="Path chiave (default: ~/.ssh/id_rsa)" class="w-full mt-1 px-2 py-1.5 rounded bg-cr-surface2 border border-cr-inputBorder text-cr-text font-mono text-xs" />
      </div>
      <button type="button" class="ssh-remove mt-2 text-cr-danger hover:text-cr-danger text-xs">Rimuovi</button>
    `;
    card.querySelector('[data-field="authType"]').addEventListener('change', function() {
      card.querySelector('.ssh-key-path-row').style.display = this.value === 'password' ? 'none' : '';
    });
    card.querySelector('.ssh-remove').addEventListener('click', () => card.remove());
    list.appendChild(card);
  });

  document.querySelectorAll('.ssh-profile-card').forEach(card => {
    card.querySelector('[data-field="authType"]')?.addEventListener('change', function() {
      card.querySelector('.ssh-key-path-row').style.display = this.value === 'password' ? 'none' : '';
    });
    card.querySelector('.ssh-remove')?.addEventListener('click', () => card.remove());
  });

  document.getElementById('btnPanicActivate').addEventListener('click', async function() {
    const confirm = await requestStrongConfirm({
      title: 'Conferma attivazione Panic Mode',
      message: 'Solo il tuo IP attuale potrà accedere fino alla scadenza.',
      expectedPhrase: 'PANIC-ACTIVATE',
    });
    if (!confirm || !confirm.ok) return;
    try {
      const durationMin = parseInt(document.getElementById('panicDurationMin')?.value || '30', 10);
      const res = await fetch('/api/settings/panic-activate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ durationMin, confirmPhrase: confirm.confirmPhrase }),
      });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Panic Mode attivo', type: 'success' } }));
        location.reload();
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Operazione fallita'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('btnPanicDisable').addEventListener('click', async function() {
    try {
      const confirm = await requestStrongConfirm({
        title: 'Conferma disattivazione Panic Mode',
        message: 'L accesso tornerà alle regole whitelist standard.',
        expectedPhrase: 'PANIC-DISABLE',
      });
      if (!confirm || !confirm.ok) return;
      const res = await fetch('/api/settings/panic-disable', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirmPhrase: confirm.confirmPhrase }),
      });
      const json = await res.json();
      if (json.ok) {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Panic Mode disattivato', type: 'success' } }));
        location.reload();
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Operazione fallita'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    }
  });

  document.getElementById('settingsForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const saveBtn = document.getElementById('btnSettingsSave');
    if (typeof window.crButtonLoading === 'function') window.crButtonLoading(saveBtn, true, 'Salvataggio…');
    var settingsSaveOk = false;
    const ipList = (form.ipWhitelist?.value || '').split('\n').map(s => s.trim()).filter(Boolean);
    const data = {
      ipWhitelistEnabled: form.ipWhitelistEnabled?.checked === true,
      ipWhitelist: ipList,
      webhookType: form.webhookType?.value || 'discord',
      webhookUrl: form.webhookUrl?.value || '',
      discordWebhookOps: form.discordWebhookOps?.value || '',
      discordWebhookIncidents: form.discordWebhookIncidents?.value || '',
      discordWebhookSecurity: form.discordWebhookSecurity?.value || '',
      telegramBotToken: form.telegramBotToken?.value || '',
      telegramChatId: form.telegramChatId?.value || '',
      notifyOnCrash: form.notifyOnCrash?.checked === true,
      notifyOnRestart: form.notifyOnRestart?.checked === true,
      notifyOnException: form.notifyOnException?.checked === true,
      notifyOnLogErr: form.notifyOnLogErr?.checked === true,
      notifyOnRunbook: form.notifyOnRunbook?.checked === true,
      notifyOnIncident: form.notifyOnIncident?.checked === true,
      notifyOnSecurity: form.notifyOnSecurity?.checked === true,
      sshProfiles: collectSshProfiles(),
      ...collectNotifyPm2Payload(),
    };
    try {
      const res = await fetch('/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (json.ok) {
        settingsSaveOk = true;
        window.dispatchEvent(new CustomEvent('toast', {
          detail: { message: 'Impostazioni salvate correttamente.', type: 'success', duration: 6200 },
        }));
      } else {
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + (json.error || 'Salvataggio fallito'), type: 'error' } }));
      }
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore: ' + err.message, type: 'error' } }));
    } finally {
      if (saveBtn && typeof window.crButtonLoading === 'function') window.crButtonLoading(saveBtn, false);
    }
    if (settingsSaveOk && typeof window.crButtonSavedFlash === 'function') window.crButtonSavedFlash(saveBtn, 'Salvato ✓', 2000);
  });
</script>
