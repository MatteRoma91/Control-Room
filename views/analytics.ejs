<section class="space-y-6" aria-labelledby="analytics-heading">
  <div class="flex items-center justify-between">
    <h1 id="analytics-heading" class="text-2xl font-bold text-slate-100">Analytics & Capacity</h1>
    <button id="btnRefreshAnalytics" class="px-3 py-1.5 rounded bg-slate-700 hover:bg-slate-600 text-sm">Aggiorna</button>
  </div>
  <div id="analyticsCards" class="grid grid-cols-1 md:grid-cols-3 gap-4"></div>
</section>

<script>
  async function loadAnalytics() {
    const root = document.getElementById('analyticsCards');
    root.innerHTML = '<div class="text-slate-400">Caricamento...</div>';
    try {
      const res = await fetch('/api/analytics/overview');
      const a = await res.json();
      if (!a.ok) throw new Error(a.error || 'Errore analytics');
      root.innerHTML = `
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">Runbook success rate</p><p class="text-2xl font-bold">${a.runbookSuccessRate}%</p></div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">Incidenti aperti</p><p class="text-2xl font-bold">${a.incidentsOpen}</p></div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">Capacity risk</p><p class="text-2xl font-bold">${a.capacityRisk}</p></div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">CPU media</p><p class="text-xl font-bold">${a.cpuAvgPercent}%</p></div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">RAM media</p><p class="text-xl font-bold">${a.ramAvgPercent}%</p></div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4"><p class="text-sm text-slate-400">Runbook totali</p><p class="text-xl font-bold">${a.runbooksTotal}</p></div>
      `;
    } catch (err) {
      root.innerHTML = `<div class="text-red-300">Errore: ${err.message}</div>`;
    }
  }

  document.getElementById('btnRefreshAnalytics').addEventListener('click', loadAnalytics);
  loadAnalytics();
</script>
