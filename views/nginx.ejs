<section class="mb-8" aria-labelledby="nginx-heading">
  <h1 id="nginx-heading" class="text-2xl font-bold text-slate-200 mb-6">Nginx Config Generator</h1>
  <p class="text-slate-400 mb-6">Genera e applica la configurazione Nginx per un nuovo dominio. Il file viene creato in <code class="text-emerald-400">/etc/nginx/sites-available/</code>, viene creato il symlink in sites-enabled e Nginx viene ricaricato.</p>

  <div class="rounded-lg border border-slate-700 bg-slate-800 p-6 max-w-xl">
    <form id="nginxForm" class="space-y-4">
      <div>
        <label for="nginxDomain" class="block text-sm text-slate-400 mb-1">Dominio</label>
        <input type="text" id="nginxDomain" name="domain" required
          placeholder="api.miosito.com"
          class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 font-mono" />
      </div>
      <div>
        <label for="nginxPort" class="block text-sm text-slate-400 mb-1">Porta locale (app Node.js)</label>
        <input type="number" id="nginxPort" name="port" value="3000" min="1" max="65535" required
          class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100" />
      </div>
      <div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="nginxSsl" name="ssl" value="1"
            class="rounded border-slate-600 bg-slate-700 text-emerald-500 focus:ring-emerald-500" />
          <span class="text-slate-300">Configura SSL con Certbot (richiede che il dominio punti già al server)</span>
        </label>
      </div>
      <button type="submit" id="btnNginxGenerate" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500">
        Genera e applica
      </button>
      <button type="button" id="btnNginxPreview" class="px-4 py-2 rounded-lg bg-slate-600 hover:bg-slate-500 ml-2">
        Preview config
      </button>
    </form>
    <div id="nginxOutput" class="mt-4 p-4 bg-slate-900 rounded-lg font-mono text-sm text-slate-300 hidden"></div>
    <div id="nginxRollbackWrap" class="mt-3 hidden">
      <button type="button" id="btnNginxRollback" class="px-4 py-2 rounded-lg bg-amber-700 hover:bg-amber-600 text-amber-100">Rollback ultima config</button>
    </div>
  </div>

  <div class="mt-6 p-4 bg-amber-900/30 border border-amber-700/50 rounded-lg text-sm text-amber-200 max-w-xl">
    <strong>Nota:</strong> Richiede permessi sudo. Aggiungi al file <code class="text-amber-300">/etc/sudoers.d/control-room-nginx</code>:
    <pre class="mt-2 text-xs overflow-x-auto">ubuntu ALL=(ALL) NOPASSWD: /usr/bin/cp /tmp/controlroom-nginx-*.conf /etc/nginx/sites-available/
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/ln -sf /etc/nginx/sites-available/* /etc/nginx/sites-enabled/
ubuntu ALL=(ALL) NOPASSWD: /usr/sbin/nginx -t
ubuntu ALL=(ALL) NOPASSWD: /bin/systemctl reload nginx
ubuntu ALL=(ALL) NOPASSWD: /usr/bin/certbot certonly --nginx -d *</pre>
  </div>
</section>

<script>
  let lastRollbackHint = '';

  document.getElementById('btnNginxPreview').addEventListener('click', async function() {
    const domain = document.getElementById('nginxDomain').value.trim();
    const port = parseInt(document.getElementById('nginxPort').value || '3000', 10);
    const output = document.getElementById('nginxOutput');
    output.classList.remove('hidden');
    output.textContent = 'Generazione preview...';
    try {
      const res = await fetch('/api/nginx-preview', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ domain, port })
      });
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'Preview fallita');
      output.textContent = json.config;
      output.className = 'mt-4 p-4 bg-slate-900 rounded-lg font-mono text-sm text-slate-300';
    } catch (err) {
      output.textContent = 'Errore preview: ' + err.message;
      output.className = 'mt-4 p-4 bg-slate-900 rounded-lg font-mono text-sm text-red-400';
    }
  });

  document.getElementById('nginxForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const domain = document.getElementById('nginxDomain').value.trim();
    const port = parseInt(document.getElementById('nginxPort').value || '3000', 10);
    const ssl = document.getElementById('nginxSsl').checked;
    const output = document.getElementById('nginxOutput');
    output.classList.remove('hidden');
    output.textContent = 'Elaborazione in corso...';
    document.getElementById('btnNginxGenerate').disabled = true;
    try {
      const res = await fetch('/api/nginx-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ domain, port, ssl })
      });
      const json = await res.json();
      output.textContent = (json.output || '') + (json.error ? '\n\nErrore: ' + json.error : '');
      output.className = 'mt-4 p-4 bg-slate-900 rounded-lg font-mono text-sm ' + (json.ok ? 'text-emerald-300' : 'text-red-400');
      if (json.ok) {
        lastRollbackHint = json.rollbackHint || '';
        document.getElementById('nginxRollbackWrap').classList.toggle('hidden', !lastRollbackHint);
        window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Configurazione Nginx applicata', type: 'success' } }));
      }
    } catch (err) {
      output.textContent = 'Errore: ' + err.message;
      output.className = 'mt-4 p-4 bg-slate-900 rounded-lg font-mono text-sm text-red-400';
    }
    document.getElementById('btnNginxGenerate').disabled = false;
  });

  document.getElementById('btnNginxRollback').addEventListener('click', async function() {
    const domain = document.getElementById('nginxDomain').value.trim();
    if (!lastRollbackHint || !domain) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Rollback non disponibile', type: 'error' } }));
      return;
    }
    try {
      const res = await fetch('/api/nginx-rollback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ backupPath: lastRollbackHint, domain })
      });
      const json = await res.json();
      if (!json.ok) throw new Error(json.error || 'Rollback fallito');
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Rollback Nginx completato', type: 'success' } }));
    } catch (err) {
      window.dispatchEvent(new CustomEvent('toast', { detail: { message: 'Errore rollback: ' + err.message, type: 'error' } }));
    }
  });
</script>
