<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verifica 2FA - Control Room</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-900 flex items-center justify-center p-4">
  <main class="w-full max-w-md" role="main">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-slate-100">Control Room</h1>
      <p class="text-slate-400 mt-2">Autenticazione a due fattori</p>
    </div>
    <div class="bg-slate-800 rounded-xl shadow-xl p-8 border border-slate-700">
      <% if (typeof rateLimited !== 'undefined' && rateLimited) { %>
        <div class="mb-4 p-3 bg-amber-900/50 border border-amber-700 rounded-lg text-amber-200 text-sm" role="alert">
          Troppi tentativi. Riprova tra 15 minuti.
        </div>
      <% } else if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-200 text-sm" role="alert">
          Codice non valido. Riprova.
        </div>
      <% } %>
      <form method="POST" action="/login/2fa" class="space-y-6" aria-labelledby="2fa-heading">
        <h2 id="2fa-heading" class="sr-only">Inserisci codice da Google Authenticator</h2>
        <p class="text-slate-300 text-sm">Inserisci il codice a 6 cifre generato da Google Authenticator o da un'app compatibile.</p>
        <div>
          <label for="code" class="block text-sm font-medium text-slate-300 mb-2">Codice</label>
          <input
            type="text"
            id="code"
            name="code"
            required
            autofocus
            autocomplete="one-time-code"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            aria-required="true"
            aria-describedby="code-hint"
            class="w-full px-4 py-2 rounded-lg bg-slate-700 border border-slate-600 text-slate-100 placeholder-slate-500 focus:ring-2 focus:ring-emerald-500 focus:border-transparent focus:outline-none text-center text-2xl tracking-[0.5em] font-mono"
            placeholder="000000"
          />
          <p id="code-hint" class="mt-1 text-xs text-slate-500">Codice a 6 cifre</p>
        </div>
        <button
          type="submit"
          class="w-full py-2.5 px-4 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-medium transition focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-slate-900 focus:outline-none"
          aria-label="Verifica codice"
        >
          Verifica
        </button>
      </form>
      <p class="mt-4 text-center">
        <a href="/login" class="text-slate-400 hover:text-slate-200 text-sm">Torna al login</a>
      </p>
    </div>
  </main>
</body>
</html>
