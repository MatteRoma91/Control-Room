<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Control Room - PM2 Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-slate-900 text-slate-100">
  <header class="bg-slate-800 border-b border-slate-700 px-6 py-4 flex justify-between items-center">
    <h1 class="text-xl font-bold">Control Room</h1>
    <form method="POST" action="/logout" class="inline">
      <button type="submit" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600 text-slate-200 text-sm">
        Logout
      </button>
    </form>
  </header>

  <main class="p-6 max-w-6xl mx-auto">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-4 p-4 bg-red-900/50 border border-red-700 rounded-lg text-red-200">
        Errore PM2: <%= error %>
      </div>
    <% } %>

    <!-- Overview Server -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Overview Server</h2>
      <div id="systemOverview" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
          <div class="text-sm text-slate-400">Uptime</div>
          <div id="sysUptime" class="text-lg font-mono">-</div>
        </div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
          <div class="text-sm text-slate-400">Load 1m</div>
          <div id="sysCpu" class="text-lg font-mono">-</div>
        </div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
          <div class="text-sm text-slate-400">RAM</div>
          <div id="sysMem" class="text-lg font-mono">-</div>
        </div>
        <div class="rounded-lg border border-slate-700 bg-slate-800 p-4">
          <div class="text-sm text-slate-400">Disco</div>
          <div id="sysDisk" class="text-lg font-mono">-</div>
        </div>
      </div>
      <div class="flex flex-wrap gap-4 items-center">
        <span id="nginxStatus" class="text-sm text-slate-400">Nginx: -</span>
        <button id="btnNginxReload" onclick="nginxReload()" class="px-3 py-1.5 rounded text-sm bg-slate-700 hover:bg-slate-600">
          Reload Nginx
        </button>
      </div>
    </section>

    <!-- Azioni globali -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Azioni globali</h2>
      <div class="flex flex-wrap gap-4">
        <button onclick="restartAllWebapps()" class="px-4 py-2 rounded-lg bg-blue-700 hover:bg-blue-600">
          Riavvia tutte le webapp
        </button>
        <button onclick="restoreAll()" class="px-4 py-2 rounded-lg bg-emerald-700 hover:bg-emerald-600">
          Ripristina tutti i processi
        </button>
      </div>
    </section>

    <!-- Link rapidi -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Link rapidi</h2>
      <div class="flex flex-wrap gap-4">
        <a href="https://bananapadeltour.duckdns.org" target="_blank" rel="noopener" class="text-emerald-400 hover:underline">Banana Padel Tour</a>
        <a href="https://ibuche.duckdns.org" target="_blank" rel="noopener" class="text-emerald-400 hover:underline">Roma-Buche</a>
        <a href="https://matteroma.duckdns.org" target="_blank" rel="noopener" class="text-emerald-400 hover:underline">Control Room</a>
      </div>
    </section>

    <!-- Health check -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Health check webapp</h2>
      <button onclick="checkHealth()" class="mb-4 px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600">
        Verifica
      </button>
      <div id="healthResults" class="overflow-x-auto rounded-lg border border-slate-700 bg-slate-800 hidden">
        <table class="w-full">
          <thead class="bg-slate-700/50">
            <tr>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Webapp</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">URL</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Status</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Tempo (ms)</th>
            </tr>
          </thead>
          <tbody id="healthBody"></tbody>
        </table>
      </div>
    </section>

    <!-- Processi PM2 -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Processi PM2</h2>
      <div class="overflow-x-auto rounded-lg border border-slate-700 bg-slate-800">
        <table class="w-full">
          <thead class="bg-slate-700/50">
            <tr>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Nome</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Status</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">CPU %</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Memory</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Uptime</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Restarts</th>
              <th class="text-left px-4 py-3 text-slate-300 font-medium">Azioni</th>
            </tr>
          </thead>
          <tbody>
            <% (processes || []).forEach((p) => { %>
              <tr class="border-t border-slate-700 hover:bg-slate-700/30">
                <td class="px-4 py-3 font-mono"><%= p.name %></td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 rounded text-xs font-medium <%= p.status === 'online' ? 'bg-emerald-900/60 text-emerald-300' : 'bg-amber-900/60 text-amber-300' %>">
                    <%= p.status %>
                  </span>
                </td>
                <td class="px-4 py-3"><%= p.cpu %>%</td>
                <td class="px-4 py-3"><%= p.memory %> MB</td>
                <td class="px-4 py-3"><%= p.uptime %></td>
                <td class="px-4 py-3"><%= p.restart_time %></td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    <button onclick="processAction('<%= p.name %>', 'start')" class="px-2 py-1 rounded text-xs bg-emerald-700 hover:bg-emerald-600">Start</button>
                    <button onclick="processAction('<%= p.name %>', 'stop')" class="px-2 py-1 rounded text-xs bg-amber-700 hover:bg-amber-600">Stop</button>
                    <button onclick="processAction('<%= p.name %>', 'restart')" class="px-2 py-1 rounded text-xs bg-blue-700 hover:bg-blue-600">Restart</button>
                  </div>
                </td>
              </tr>
            <% }); %>
            <% if (!processes || processes.length === 0) { %>
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-slate-500">Nessun processo PM2</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Reload Logs -->
    <section>
      <h2 class="text-lg font-semibold text-slate-200 mb-4">Reload Logs</h2>
      <div class="flex flex-wrap gap-4 items-end mb-4">
        <div>
          <label for="logProcess" class="block text-sm text-slate-400 mb-1">Processo</label>
          <select id="logProcess" class="px-4 py-2 rounded-lg bg-slate-800 border border-slate-600 text-slate-100">
            <option value="">Seleziona processo</option>
            <% (processes || []).forEach((p) => { %>
              <option value="<%= p.name %>"><%= p.name %></option>
            <% }); %>
          </select>
        </div>
        <button onclick="loadLogs()" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600">
          Carica log
        </button>
      </div>
      <div id="logsContainer" class="hidden rounded-lg border border-slate-700 bg-slate-800 overflow-hidden">
        <div class="border-b border-slate-700 p-2 bg-slate-700/50 text-sm font-medium">stdout</div>
        <pre id="stdout" class="p-4 overflow-auto max-h-64 text-xs text-slate-300 font-mono whitespace-pre-wrap"></pre>
        <div class="border-t border-slate-700 p-2 bg-slate-700/50 text-sm font-medium text-red-300">stderr</div>
        <pre id="stderr" class="p-4 overflow-auto max-h-64 text-xs text-red-200/80 font-mono whitespace-pre-wrap"></pre>
      </div>
    </section>
  </main>

  <script>
    async function processAction(name, action) {
      try {
        const res = await fetch(`/api/process/${action}/${encodeURIComponent(name)}`, { method: 'POST' });
        const data = await res.json();
        if (data.ok) location.reload();
        else alert('Errore: ' + (data.error || 'Operazione fallita'));
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    async function loadLogs() {
      const name = document.getElementById('logProcess').value;
      if (!name) {
        alert('Seleziona un processo');
        return;
      }
      try {
        const res = await fetch(`/api/logs/${encodeURIComponent(name)}`);
        const data = await res.json();
        const container = document.getElementById('logsContainer');
        if (data.stdout !== undefined) {
          document.getElementById('stdout').textContent = data.stdout || '(vuoto)';
          document.getElementById('stderr').textContent = data.stderr || '(vuoto)';
          container.classList.remove('hidden');
        } else {
          alert('Errore: ' + (data.error || 'Caricamento log fallito'));
        }
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    async function loadSystem() {
      try {
        const [sysRes, nginxRes] = await Promise.all([
          fetch('/api/system'),
          fetch('/api/nginx-status')
        ]);
        const sys = await sysRes.json();
        const nginx = await nginxRes.json();
        if (sys.uptime !== undefined) {
          document.getElementById('sysUptime').textContent = sys.uptime;
          document.getElementById('sysCpu').textContent = sys.loadAvg1;
          document.getElementById('sysMem').textContent = sys.memoryUsedMB + ' / ' + sys.memoryTotalMB + ' MB (' + sys.memoryPercent + '%)';
          document.getElementById('sysDisk').textContent = sys.diskUsedGB + ' / ' + sys.diskTotalGB + ' GB (' + sys.diskPercent + '%)';
        }
        document.getElementById('nginxStatus').textContent = 'Nginx: ' + (nginx.active ? 'attivo' : 'non attivo');
      } catch (e) {
        document.getElementById('sysUptime').textContent = 'Errore';
      }
    }

    async function restartAllWebapps() {
      try {
        const res = await fetch('/api/process/restart-all', { method: 'POST' });
        const data = await res.json();
        if (data.ok) location.reload();
        else alert('Errore: ' + (data.error || 'Operazione fallita'));
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    async function restoreAll() {
      try {
        const res = await fetch('/api/process/restore-all', { method: 'POST' });
        const data = await res.json();
        if (data.ok) location.reload();
        else alert('Errore: ' + (data.error || 'Operazione fallita'));
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    async function checkHealth() {
      try {
        const res = await fetch('/api/health');
        const data = await res.json();
        const tbody = document.getElementById('healthBody');
        const container = document.getElementById('healthResults');
        tbody.innerHTML = '';
        (data.results || []).forEach(function(r) {
          const tr = document.createElement('tr');
          tr.className = 'border-t border-slate-700';
          const statusCls = r.ok ? 'text-emerald-300' : 'text-red-400';
          const statusText = r.ok ? (r.status + ' OK') : (r.error || 'Errore');
          tr.innerHTML = '<td class="px-4 py-3">' + (r.name || '') + '</td><td class="px-4 py-3 font-mono text-sm">' + (r.url || '') + '</td><td class="px-4 py-3 ' + statusCls + '">' + statusText + '</td><td class="px-4 py-3">' + (r.elapsed || '-') + '</td>';
          tbody.appendChild(tr);
        });
        container.classList.remove('hidden');
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    async function nginxReload() {
      try {
        const res = await fetch('/api/nginx-reload', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
          loadSystem();
        } else {
          alert('Errore: ' + (data.error || 'Reload fallito'));
        }
      } catch (e) {
        alert('Errore: ' + e.message);
      }
    }

    loadSystem();
  </script>
</body>
</html>
