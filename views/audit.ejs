<section aria-labelledby="audit-heading">
  <div class="flex items-center justify-between gap-3 mb-4">
    <h1 id="audit-heading" class="text-2xl font-bold text-slate-200">Audit log</h1>
    <button id="btnRefreshAudit" class="px-4 py-2 rounded-lg bg-slate-700 hover:bg-slate-600">Aggiorna</button>
  </div>
  <p class="text-sm text-slate-400 mb-4">Storico azioni amministrative e operazioni sensibili.</p>
  <div class="rounded-lg border border-slate-700 bg-slate-800 overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-slate-700/50">
        <tr>
          <th class="text-left px-4 py-2">Timestamp</th>
          <th class="text-left px-4 py-2">Evento</th>
          <th class="text-left px-4 py-2">Utente</th>
          <th class="text-left px-4 py-2">Dettagli</th>
        </tr>
      </thead>
      <tbody id="auditBody">
        <tr><td colspan="4" class="px-4 py-6 text-center text-slate-500">Caricamento...</td></tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  function esc(v) {
    const d = document.createElement('div');
    d.textContent = String(v == null ? '' : v);
    return d.innerHTML;
  }
  function compactDetails(ev) {
    const clone = { ...ev };
    delete clone.ts;
    delete clone.event;
    const str = JSON.stringify(clone);
    return str.length > 180 ? str.slice(0, 180) + '…' : str;
  }
  async function loadAudit() {
    try {
      const res = await fetch('/api/audit/events?limit=200');
      const json = await res.json();
      const rows = (json.events || []).map((ev) => (
        `<tr class="border-t border-slate-700 hover:bg-slate-700/30">
          <td class="px-4 py-2 whitespace-nowrap">${esc(new Date(ev.ts).toLocaleString('it-IT'))}</td>
          <td class="px-4 py-2 font-mono text-emerald-300">${esc(ev.event || '-')}</td>
          <td class="px-4 py-2">${esc(ev.user || 'system')}</td>
          <td class="px-4 py-2 text-slate-400" title="${esc(JSON.stringify(ev))}">${esc(compactDetails(ev))}</td>
        </tr>`
      )).join('');
      document.getElementById('auditBody').innerHTML = rows || '<tr><td colspan="4" class="px-4 py-6 text-center text-slate-500">Nessun evento</td></tr>';
    } catch (e) {
      document.getElementById('auditBody').innerHTML = `<tr><td colspan="4" class="px-4 py-6 text-center text-red-400">Errore: ${esc(e.message)}</td></tr>`;
    }
  }
  document.getElementById('btnRefreshAudit').addEventListener('click', loadAudit);
  loadAudit();
</script>
