AUTH_USER=admin
AUTH_PASSWORD=change_me_with_a_strong_password
SESSION_SECRET=change_me_with_a_random_secret_min_32_chars
SESSION_MAX_AGE_DAYS=7
SESSION_IDLE_MINUTES=120
SESSION_REDIS_REQUIRED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=cr:sess:
REDIS_CONNECT_TIMEOUT_MS=5000

# Discord webhooks (opzionali, override routing notifiche)
DISCORD_WEBHOOK_OPS=
DISCORD_WEBHOOK_INCIDENTS=
DISCORD_WEBHOOK_SECURITY=
CR_ALLOWED_ORIGINS=https://matteroma.duckdns.org
PORT=3005

# Database MySQL (opzionale, per backup)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=myapp
